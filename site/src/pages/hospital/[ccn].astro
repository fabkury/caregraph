---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import {
  HOSPITAL_TYPE_INFO,
  OWNERSHIP_CATEGORIES,
  HRRP_CONDITIONS,
  VBP_DOMAINS,
  STAR_DOMAINS,
  PAYMENT_PROGRAMS,
  BENCHMARK_KEYS,
  type HrrpCondition,
} from '../../config/hospital-fields';
import {
  buildAllDataCsv,
  flattenDataset,
  heuristicFormat,
  pctlClass as allDataPctlClass,
  type AllDataRow,
} from '../../config/all-data';

// ── Load benchmark data (shared across all hospital pages) ──────────

const benchmarksPath = path.resolve(process.cwd(), '..', 'site_data', 'hospital_benchmarks.json');
let benchmarkData: any = null;
try { benchmarkData = JSON.parse(fs.readFileSync(benchmarksPath, 'utf-8')); } catch {}

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'hospital');
  const paths: Array<{ params: { ccn: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { ccn: manifest.ccn },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { ccn } = Astro.params;

// ── Extract data ────────────────────────────────────────────────────

const name = manifest.facility_name;
const rating = manifest.hospital_overall_rating;
const ratingNum = rating && rating !== 'Not Available' ? parseInt(rating) : null;
const generalInfo = manifest.data?.general_info || {};
const readmissions = manifest.data?.readmissions || null;
const vbp = manifest.data?.vbp || null;
const timelyCare = manifest.data?.timely_effective_care || null;
const complications = manifest.data?.complications_deaths || null;
const hcahps = manifest.data?.hcahps || null;
const hai = manifest.data?.hai || null;
const unplannedVisits = manifest.data?.unplanned_visits || null;
const mspb = manifest.data?.mspb || null;
const hacData = manifest.data?.hac_reduction || null;
const costReport = manifest.data?.cost_report || null;
const related = manifest.related || [];
const provenance = manifest.provenance || [];

const hospitalType = manifest.hospital_type || '';
const typeInfo = HOSPITAL_TYPE_INFO[hospitalType] || null;
const ownership = manifest.hospital_ownership || '';
const ownershipShort = OWNERSHIP_CATEGORIES[ownership] || ownership;
const birthing = generalInfo['Meets criteria for birthing friendly designation'];

// ── Benchmark helpers ───────────────────────────────────────────────

const bm = benchmarkData?.benchmarks || {};
const hospitalRanks: Record<string, number> = benchmarkData?.hospital_ranks?.[ccn as string] || {};

function bmMedian(key: string): number | null {
  return bm[key]?.p50 ?? null;
}

function pctlBadge(key: string): string {
  const p = hospitalRanks[key];
  if (p === undefined) return '';
  return `p${p}`;
}

function pctlClass(key: string, inverted = false): string {
  const p = hospitalRanks[key];
  if (p === undefined) return '';
  if (inverted) {
    // Lower is better: low percentile = good (green)
    if (p <= 25) return 'pctl-high';
    if (p >= 75) return 'pctl-low';
    return 'pctl-mid';
  }
  if (p <= 25) return 'pctl-low';
  if (p >= 75) return 'pctl-high';
  return 'pctl-mid';
}

// ── HRRP derived metrics ────────────────────────────────────────────

const hrrpMeasures: Array<{ condition: HrrpCondition; err: number | null; predicted: number | null; expected: number | null; discharges: number | null; readmissions: number | null }> = [];
let worstErr: number | null = null;
let hrrpPenalized = false;

if (readmissions) {
  for (const cond of HRRP_CONDITIONS) {
    const d = readmissions[cond.measureId];
    if (!d) continue;
    const err = d.excess_readmission_ratio ?? null;
    hrrpMeasures.push({
      condition: cond,
      err,
      predicted: d.predicted_readmission_rate ?? null,
      expected: d.expected_readmission_rate ?? null,
      discharges: d.num_discharges ?? null,
      readmissions: d.num_readmissions ?? null,
    });
    if (err !== null) {
      if (worstErr === null || err > worstErr) worstErr = err;
      if (err > 1) hrrpPenalized = true;
    }
  }
}

// ── VBP derived ─────────────────────────────────────────────────────

const vbpTps = vbp?.total_performance_score ?? null;
const vbpMedian = bmMedian(BENCHMARK_KEYS.vbp_tps);
const vbpAboveMedian = vbpTps !== null && vbpMedian !== null ? vbpTps >= vbpMedian : null;

// ── HAC derived ─────────────────────────────────────────────────────

const hacReduced = hacData?.payment_reduction === true || hacData?.payment_reduced === true;

// ── Star rating breakdown ───────────────────────────────────────────

const starDomainData = STAR_DOMAINS.map(domain => {
  const groupCount = parseInt(generalInfo[domain.groupCountKey]) || 0;
  const facilityCount = parseInt(generalInfo[domain.facilityCountKey]) || 0;
  const better = domain.betterKey ? parseInt(generalInfo[domain.betterKey]) || 0 : null;
  const noDiff = domain.noDiffKey ? parseInt(generalInfo[domain.noDiffKey]) || 0 : null;
  const worse = domain.worseKey ? parseInt(generalInfo[domain.worseKey]) || 0 : null;
  return { domain, groupCount, facilityCount, better, noDiff, worse };
}).filter(d => d.facilityCount > 0);

// ── Build "All Data" rows (drives the All Data section + CSV) ──────

const HOSPITAL_GROUP_LABELS: Record<string, string> = {
  general_info: 'General Information',
  readmissions: 'Readmissions (HRRP)',
  vbp: 'Value-Based Purchasing',
  timely_effective_care: 'Timely & Effective Care',
  complications_deaths: 'Complications & Deaths',
  hcahps: 'Patient Experience (HCAHPS)',
  hai: 'Healthcare-Associated Infections',
  unplanned_visits: 'Unplanned Hospital Visits',
  mspb: 'Medicare Spending per Beneficiary',
  hac_reduction: 'HAC Reduction Program',
  cost_report: 'Cost Report',
};

const READMISSION_ATTR_LABELS: Record<string, string> = {
  excess_readmission_ratio: 'Excess readmission ratio',
  predicted_readmission_rate: 'Predicted readmission rate',
  expected_readmission_rate: 'Expected readmission rate',
  num_readmissions: 'Number of readmissions',
  num_discharges: 'Number of discharges',
};

const hrrpLabelById: Record<string, string> = {};
for (const c of HRRP_CONDITIONS) hrrpLabelById[c.measureId] = c.label;

const allDataRows: AllDataRow[] = [];

// General info — CMS ships these with human-readable CSV headers already.
for (const [k, v] of Object.entries(generalInfo)) {
  if (v === null || v === undefined) continue;
  const s = String(v).trim();
  allDataRows.push({
    group: HOSPITAL_GROUP_LABELS.general_info,
    rawKey: k,
    label: k,
    value: s === '' ? '\u2014' : s,
    bmMedian: '\u2014',
    percentile: undefined,
  });
}

// VBP domain scores (labels + benchmarks from hospital_benchmarks.json).
if (vbp) {
  for (const d of VBP_DOMAINS) {
    const val = (vbp as any)[d.key];
    if (val === null || val === undefined) continue;
    const bmKey = `vbp.${d.key}`;
    const bmEntry = bm[bmKey];
    const p = hospitalRanks[bmKey];
    allDataRows.push({
      group: HOSPITAL_GROUP_LABELS.vbp,
      rawKey: d.key,
      label: d.label,
      value: typeof val === 'number' ? val.toFixed(2) : String(val),
      bmMedian: bmEntry && typeof bmEntry.p50 === 'number' ? bmEntry.p50.toFixed(2) : '\u2014',
      percentile: typeof p === 'number' ? p : undefined,
    });
  }
}

// Readmissions — one row per HRRP measure × attribute.
if (readmissions) {
  for (const [measureId, attrs] of Object.entries(readmissions)) {
    if (!attrs || typeof attrs !== 'object') continue;
    const condLabel = hrrpLabelById[measureId] || measureId;
    for (const [attrKey, val] of Object.entries(attrs as Record<string, any>)) {
      if (val === null || val === undefined) continue;
      const bmKey = attrKey === 'excess_readmission_ratio' ? `hrrp.${measureId}` : '';
      const bmEntry = bmKey ? bm[bmKey] : null;
      const p = bmKey ? hospitalRanks[bmKey] : undefined;
      allDataRows.push({
        group: HOSPITAL_GROUP_LABELS.readmissions,
        rawKey: `${measureId}.${attrKey}`,
        label: `${condLabel} — ${READMISSION_ATTR_LABELS[attrKey] || attrKey}`,
        value: heuristicFormat(val, attrKey),
        bmMedian: bmEntry && typeof bmEntry.p50 === 'number' ? bmEntry.p50.toFixed(4) : '\u2014',
        percentile: typeof p === 'number' ? p : undefined,
      });
    }
  }
}

// Any other data.* subkey — flatten generically so pages don't break when
// new enrichments land. Delegated to shared helper so hospital + SNF emit
// consistent rows and both handle {value,label} metric envelopes, deeper
// nesting, and arrays of structured records.
const handledDsKeys = new Set(['general_info', 'vbp', 'readmissions']);
for (const [dsKey, ds] of Object.entries(manifest.data || {})) {
  if (handledDsKeys.has(dsKey)) continue;
  const groupLabel = HOSPITAL_GROUP_LABELS[dsKey] || dsKey.replace(/_/g, ' ');
  flattenDataset(groupLabel, ds, allDataRows);
}

allDataRows.sort((a, b) => {
  if (a.group !== b.group) return a.group.localeCompare(b.group);
  return a.label.localeCompare(b.label);
});

const allDataCsvUri = buildAllDataCsv(allDataRows);

// ── Section nav items ───────────────────────────────────────────────

const sections: Array<{ id: string; label: string }> = [
  { id: 'overview', label: 'Overview' },
];
if (starDomainData.length > 0) sections.push({ id: 'star-breakdown', label: 'Star Rating' });
if (hrrpMeasures.length > 0) sections.push({ id: 'readmissions', label: 'Readmissions' });
if (vbp) sections.push({ id: 'vbp', label: 'Value-Based Purchasing' });
if (readmissions || vbp || hacData) sections.push({ id: 'payment-programs', label: 'Payment Programs' });
if (complications && complications.length > 0) sections.push({ id: 'complications', label: 'Complications & Deaths' });
if (hcahps && hcahps.length > 0) sections.push({ id: 'hcahps', label: 'Patient Experience' });
if (hai && hai.length > 0) sections.push({ id: 'hai', label: 'Infections' });
if (timelyCare && timelyCare.length > 0) sections.push({ id: 'timely-care', label: 'Timely Care' });
if (unplannedVisits && unplannedVisits.length > 0) sections.push({ id: 'unplanned-visits', label: 'Unplanned Visits' });
if (mspb) sections.push({ id: 'mspb', label: 'Medicare Spending' });
if (costReport) sections.push({ id: 'financial', label: 'Financial Health' });
if (related.length > 0) sections.push({ id: 'related', label: 'Related' });
if (allDataRows.length > 0) sections.push({ id: 'all-data', label: 'All Data' });

// ── Helpers ─────────────────────────────────────────────────────────

function entityUrl(rel: { type: string; id: string }): string {
  return `/${rel.type}/${rel.id}/`;
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}

function errColor(err: number | null): string {
  if (err === null) return 'var(--color-text-muted)';
  if (err <= 0.97) return '#059669';
  if (err <= 1.0) return '#059669';
  if (err <= 1.05) return '#d97706';
  return '#dc2626';
}

function errLabel(err: number | null): string {
  if (err === null) return 'N/A';
  if (err < 1) return 'Below expected';
  if (err === 1) return 'As expected';
  return 'Above expected';
}
---

<BaseLayout title={name} description={`${name} (CCN: ${ccn}) — Hospital profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-hospital">Hospital</span>
      <h1 style="margin: 0;">{name}</h1>
    </div>
    <p class="subtitle">
      CCN: <code>{ccn}</code> &middot; {manifest.city}, {manifest.state} {manifest.zip_code}
      {manifest.county_name && <span>&middot; {manifest.county_name} County</span>}
    </p>
  </div>

  <div class="actions-bar">
    <button class="btn" id="pin-btn" data-entity-type="hospital" data-entity-id={ccn} data-entity-name={name}>
      Pin to Workspace
    </button>
  </div>

  <!-- Section navigation -->
  <nav class="section-nav" aria-label="Data sections">
    {sections.map(s => (
      <a href={`#${s.id}`}>{s.label}</a>
    ))}
  </nav>

  <!-- Benchmark legend (only if we have benchmark data) -->
  {benchmarkData && (vbp || readmissions) && (
    <div class="benchmark-legend">
      <span class="benchmark-legend-item">
        <span class="benchmark-legend-swatch" style="background: #fee2e2;"></span> Bottom quartile
      </span>
      <span class="benchmark-legend-item">
        <span class="benchmark-legend-swatch" style="background: #fef9c3;"></span> Middle
      </span>
      <span class="benchmark-legend-item">
        <span class="benchmark-legend-swatch" style="background: #dcfce7;"></span> Top quartile
      </span>
      <span class="benchmark-legend-item" style="color: var(--color-text-muted);">
        Percentile badges compare this hospital to all {benchmarkData?.metadata?.hospital_count?.toLocaleString() || ''} hospitals nationally.
      </span>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 1. OVERVIEW                                                     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="card" id="overview">
    <h2>Overview</h2>

    <div class="hosp-overview-grid">
      <!-- Left: Key details -->
      <div>
        <dl class="kv-grid">
          <dt>Address</dt>
          <dd>{manifest.address}, {manifest.city}, {manifest.state} {manifest.zip_code}</dd>
          <dt>Phone</dt>
          <dd>{manifest.phone_number}</dd>
          <dt>Hospital Type</dt>
          <dd>{typeInfo ? typeInfo.short : hospitalType}</dd>
          <dt>Ownership</dt>
          <dd>{ownershipShort}</dd>
          <dt>Emergency Services</dt>
          <dd>
            <span class={manifest.emergency_services === 'Yes' ? 'tag-yes' : 'tag-no'}>
              {manifest.emergency_services === 'Yes' ? 'Yes' : 'No'}
            </span>
          </dd>
          {birthing && (
            <>
              <dt>Birthing Friendly</dt>
              <dd>
                <span class={birthing === 'Y' ? 'tag-yes' : 'tag-no'}>
                  {birthing === 'Y' ? 'Yes' : 'No'}
                </span>
              </dd>
            </>
          )}
        </dl>
      </div>

      <!-- Right: Star rating -->
      <div class="hosp-star-card">
        {ratingNum !== null ? (
          <>
            <div class="hosp-star-display">
              <span class="hosp-star-number">{ratingNum}</span>
              <span class="hosp-star-of">/5</span>
            </div>
            <div class="hosp-star-stars">
              {[1,2,3,4,5].map(i => (
                <span class={i <= ratingNum ? 'star-filled' : 'star-empty'}>&#9733;</span>
              ))}
            </div>
            <div class="hosp-star-label">CMS Overall Rating</div>
            {pctlBadge('star_rating') && (
              <span class={`pctl-badge ${pctlClass('star_rating')}`}>{pctlBadge('star_rating')}</span>
            )}
          </>
        ) : (
          <>
            <div class="hosp-star-display" style="opacity: 0.4;">
              <span class="hosp-star-number">&mdash;</span>
            </div>
            <div class="hosp-star-label">Star rating not available</div>
          </>
        )}
      </div>
    </div>

    <!-- Hospital type context card -->
    {typeInfo && (
      <div class="hosp-type-context">
        <strong>{typeInfo.short}</strong> &mdash; {typeInfo.detail}
      </div>
    )}
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 2. CMS STAR RATING BREAKDOWN                                    -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {starDomainData.length > 0 && (
    <div class="card" id="star-breakdown">
      <h2>CMS Star Rating — Quality Domain Breakdown</h2>
      <p class="section-help">
        CMS computes the overall star rating from five quality domains. Each domain compares this hospital's measures against national benchmarks.
      </p>

      <div class="star-domain-list">
        {starDomainData.map(({ domain, groupCount, facilityCount, better, noDiff, worse }) => {
          const hasBnw = better !== null && noDiff !== null && worse !== null;
          const total = hasBnw ? (better! + noDiff! + worse!) : facilityCount;
          return (
            <div class="star-domain-row">
              <div class="star-domain-header">
                <span class="star-domain-name">{domain.label}</span>
                <span class="star-domain-count">{facilityCount} of {groupCount} measures reported</span>
              </div>
              {hasBnw && total > 0 ? (
                <div class="star-domain-bar-container">
                  <div class="star-domain-bar">
                    {better! > 0 && (
                      <div class="star-bar-segment star-bar-better" style={`width: ${(better! / total * 100)}%`}>
                        {better}
                      </div>
                    )}
                    {noDiff! > 0 && (
                      <div class="star-bar-segment star-bar-same" style={`width: ${(noDiff! / total * 100)}%`}>
                        {noDiff}
                      </div>
                    )}
                    {worse! > 0 && (
                      <div class="star-bar-segment star-bar-worse" style={`width: ${(worse! / total * 100)}%`}>
                        {worse}
                      </div>
                    )}
                  </div>
                  <div class="star-domain-legend">
                    <span class="star-legend-item"><span class="star-legend-dot" style="background: #059669;"></span> Better</span>
                    <span class="star-legend-item"><span class="star-legend-dot" style="background: #9ca3af;"></span> No different</span>
                    <span class="star-legend-item"><span class="star-legend-dot" style="background: #dc2626;"></span> Worse</span>
                  </div>
                </div>
              ) : (
                <div class="star-domain-bar-container">
                  <div style="font-size: 0.85rem; color: var(--color-text-muted);">
                    {facilityCount} measures reported (comparative data not available for this domain)
                  </div>
                </div>
              )}
              <div class="star-domain-help">{domain.help}</div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 3. READMISSIONS (HRRP)                                         -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {hrrpMeasures.length > 0 && (
    <div class="card" id="readmissions">
      <h2>Readmissions — Hospital Readmissions Reduction Program</h2>
      <p class="section-help">
        The Excess Readmission Ratio (ERR) compares this hospital's 30-day readmission rate to expected, adjusting for patient mix.
        An ERR of 1.0 means readmissions are as expected; &gt;&nbsp;1.0 triggers a Medicare payment penalty (up to 3%).
      </p>

      <!-- HRRP penalty callout -->
      <div class={`hosp-penalty-callout ${hrrpPenalized ? 'penalty-yes' : 'penalty-no'}`}>
        <span class="penalty-icon">{hrrpPenalized ? '⚠' : '✓'}</span>
        <span>
          {hrrpPenalized
            ? 'This hospital has excess readmissions in at least one condition and is subject to HRRP payment reduction.'
            : 'This hospital does not have excess readmissions triggering HRRP penalties.'}
        </span>
      </div>

      <!-- ERR bar chart -->
      <div class="hrrp-chart">
        {hrrpMeasures.map(({ condition, err, predicted, expected, discharges, readmissions: numReadm }) => {
          const medianKey = `hrrp.${condition.measureId}`;
          const median = bmMedian(medianKey);
          // Bar width: ERR scaled so 1.0 = 50% of bar width, range 0.8-1.2
          const barPct = err !== null ? Math.min(Math.max((err - 0.8) / 0.4 * 100, 0), 100) : 0;
          const baselinePct = (1.0 - 0.8) / 0.4 * 100; // where 1.0 falls
          const medianPct = median !== null ? Math.min(Math.max((median - 0.8) / 0.4 * 100, 0), 100) : null;
          return (
            <div class="hrrp-row">
              <div class="hrrp-label">
                <span class="hrrp-condition-name">{condition.label}</span>
                {discharges !== null && (
                  <span class="hrrp-volume">{discharges.toLocaleString()} discharges</span>
                )}
              </div>
              {err !== null ? (
                <div class="hrrp-bar-container">
                  <div class="hrrp-bar-track">
                    <div class="hrrp-bar-fill" style={`width: ${barPct}%; background: ${errColor(err)};`}></div>
                    <div class="hrrp-baseline" style={`left: ${baselinePct}%;`} title="Expected (1.0)"></div>
                    {medianPct !== null && (
                      <div class="hrrp-median-marker" style={`left: ${medianPct}%;`} title={`National median: ${median!.toFixed(4)}`}></div>
                    )}
                  </div>
                  <div class="hrrp-value" style={`color: ${errColor(err)};`}>
                    {err.toFixed(4)}
                    {pctlBadge(medianKey) && (
                      <span class={`pctl-badge ${pctlClass(medianKey, true)}`}>{pctlBadge(medianKey)}</span>
                    )}
                  </div>
                </div>
              ) : (
                <div class="hrrp-bar-container">
                  <span class="hrrp-na">&mdash; Not reported</span>
                </div>
              )}
            </div>
          );
        })}
      </div>
      <div class="hrrp-bar-legend">
        <span><span class="hrrp-legend-line" style="background: #1e293b;"></span> Expected (1.0)</span>
        <span><span class="hrrp-legend-diamond"></span> National median</span>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 4. VALUE-BASED PURCHASING                                       -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {vbp && (
    <div class="card" id="vbp">
      <h2>Value-Based Purchasing</h2>
      <p class="section-help">
        The Hospital VBP Program adjusts Medicare payments based on clinical quality. The Total Performance Score (TPS) is a weighted composite of four domains, each worth 25%.
        {vbpAboveMedian !== null && (
          vbpAboveMedian
            ? <strong> This hospital's TPS is above the national median, suggesting a positive payment adjustment.</strong>
            : <strong> This hospital's TPS is below the national median, suggesting a negative payment adjustment.</strong>
        )}
      </p>

      <!-- TPS headline -->
      <div class="vbp-tps-card">
        <div class="vbp-tps-value">
          {vbpTps !== null ? vbpTps.toFixed(1) : '\u2014'}
          {pctlBadge(BENCHMARK_KEYS.vbp_tps) && (
            <span class={`pctl-badge ${pctlClass(BENCHMARK_KEYS.vbp_tps)}`}>{pctlBadge(BENCHMARK_KEYS.vbp_tps)}</span>
          )}
        </div>
        <div class="vbp-tps-label">Total Performance Score</div>
        {vbpMedian !== null && (
          <div class="vbp-tps-median">National median: {vbpMedian.toFixed(1)}</div>
        )}
      </div>

      <!-- Domain scores -->
      <div class="metric-grid" style="margin-top: 1rem;">
        {VBP_DOMAINS.filter(d => d.key !== 'total_performance_score').map(domain => {
          const val = vbp[domain.key];
          const bmKey = `vbp.${domain.key}` as string;
          const median = bmMedian(bmKey);
          if (val === null || val === undefined) return null;
          return (
            <div class="metric-card">
              <div class="label">
                {domain.label}
                <span class="vbp-weight">{domain.weight}% weight</span>
              </div>
              <div class="value">
                {typeof val === 'number' ? val.toFixed(1) : val}
                {pctlBadge(bmKey) && (
                  <span class={`pctl-badge ${pctlClass(bmKey)}`}>{pctlBadge(bmKey)}</span>
                )}
              </div>
              {median !== null && (
                <div class="metric-median">Nat'l median: {median.toFixed(1)}</div>
              )}
              <div class="metric-help">{domain.help}</div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 5. CMS PAYMENT PROGRAMS SUMMARY                                 -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {(readmissions || vbp || hacData) && (
    <div class="card" id="payment-programs">
      <h2>CMS Payment Programs</h2>
      <p class="section-help">Three Medicare programs adjust hospital payments based on quality performance. Hospitals can be penalized under multiple programs simultaneously.</p>

      <div class="metric-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <!-- HRRP -->
        <div class="metric-card" style={`border-left: 4px solid ${hrrpPenalized ? '#dc2626' : '#059669'}`}>
          <div class="label">Readmissions (HRRP)</div>
          <div class="value" style={`color: ${hrrpPenalized ? '#dc2626' : '#059669'}`}>
            {readmissions ? (hrrpPenalized ? 'Penalized' : 'Not Penalized') : '\u2014'}
          </div>
          {worstErr !== null && (
            <div class="metric-median">Worst ERR: {worstErr.toFixed(4)}</div>
          )}
        </div>

        <!-- VBP -->
        <div class="metric-card" style={`border-left: 4px solid ${vbpAboveMedian === true ? '#059669' : vbpAboveMedian === false ? '#dc2626' : '#9ca3af'}`}>
          <div class="label">Value-Based Purchasing</div>
          <div class="value" style={`color: ${vbpAboveMedian === true ? '#059669' : vbpAboveMedian === false ? '#dc2626' : 'inherit'}`}>
            {vbpTps !== null ? `${vbpTps.toFixed(1)} TPS` : '\u2014'}
          </div>
          {vbpAboveMedian !== null && (
            <div class="metric-median">{vbpAboveMedian ? 'Above' : 'Below'} national median</div>
          )}
        </div>

        <!-- HAC -->
        <div class="metric-card" style={`border-left: 4px solid ${hacData ? (hacReduced ? '#dc2626' : '#059669') : '#9ca3af'}`}>
          <div class="label">HAC Reduction</div>
          <div class="value" style={`color: ${hacData ? (hacReduced ? '#dc2626' : '#059669') : 'var(--color-text-muted)'}`}>
            {hacData ? (hacReduced ? 'Payment Reduced' : 'No Reduction') : '\u2014'}
          </div>
          {hacData?.total_hac_score != null && (
            <div class="metric-median">HAC Score: {hacData.total_hac_score.toFixed(4)}</div>
          )}
        </div>
      </div>

      {hacData?.measures && hacData.measures.length > 0 && (
        <details style="margin-top: 1rem;">
          <summary style="cursor: pointer; font-weight: 500; font-size: 0.9rem;">HAC Component Scores</summary>
          <table class="data-table" style="margin-top: 0.5rem;">
            <thead><tr><th>Measure</th><th style="text-align:right">SIR</th><th style="text-align:right">Z-Score</th></tr></thead>
            <tbody>
              {hacData.measures.map((m: any) => (
                <tr>
                  <td style="font-weight: 500;">{m.measure_name || m.measure_id || '\u2014'}</td>
                  <td style={`text-align:right; color: ${m.sir != null && m.sir < 0.8 ? '#059669' : m.sir != null && m.sir > 1.2 ? '#dc2626' : 'inherit'}`}>
                    {m.sir != null ? m.sir.toFixed(3) : '\u2014'}
                  </td>
                  <td style="text-align:right">{m.z_score != null ? m.z_score.toFixed(3) : '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      )}
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 6. COMPLICATIONS & DEATHS                                       -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {complications && complications.length > 0 && (
    <div class="card" id="complications">
      <h2>Complications & Deaths</h2>
      <p class="section-help">30-day mortality rates, patient safety indicators, and complication rates. "Better" means statistically significantly better than the national rate.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Measure</th>
              <th>Score</th>
              <th>vs. National</th>
              <th>Denominator</th>
            </tr>
          </thead>
          <tbody>
            {complications.map((row: any) => {
              const measureId = row['Measure ID'] || row['Measure Name'] || '';
              const score = row['Score'] ?? row['Rate'] ?? null;
              const compared = row['Compared to National'] || row['Compared To National'] || '';
              const denom = row['Denominator'] ?? row['Number of Patients'] ?? '';
              const compColor = compared.includes('Better') ? '#059669' : compared.includes('Worse') ? '#dc2626' : 'inherit';
              return (
                <tr>
                  <td style="font-weight: 500;">{measureId}</td>
                  <td>{score !== null ? (typeof score === 'number' ? score.toFixed(2) : score) : '\u2014'}</td>
                  <td style={`color: ${compColor}; font-weight: ${compared.includes('Better') || compared.includes('Worse') ? '600' : '400'};`}>{compared || '\u2014'}</td>
                  <td>{typeof denom === 'number' ? denom.toLocaleString() : denom || '\u2014'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 7. PATIENT EXPERIENCE (HCAHPS)                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {hcahps && hcahps.length > 0 && (
    <div class="card" id="hcahps">
      <h2>Patient Experience (HCAHPS)</h2>
      <p class="section-help">Hospital Consumer Assessment of Healthcare Providers and Systems — standardized patient survey measuring satisfaction with care.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Measure</th>
              <th>Score</th>
              <th>Star Rating</th>
            </tr>
          </thead>
          <tbody>
            {hcahps.map((row: any) => {
              const measureId = row['HCAHPS Measure ID'] || row['Measure ID'] || '';
              const answer = row['HCAHPS Answer Description'] || '';
              const pct = row['HCAHPS Answer Percent'] ?? row['Score'] ?? '';
              const star = row['Patient Survey Star Rating'] ?? '';
              return (
                <tr>
                  <td style="font-weight: 500;">{measureId}{answer ? `: ${answer}` : ''}</td>
                  <td>{typeof pct === 'number' ? `${pct}%` : pct || '\u2014'}</td>
                  <td>{star || '\u2014'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 8. HEALTHCARE ASSOCIATED INFECTIONS                             -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {hai && hai.length > 0 && (
    <div class="card" id="hai">
      <h2>Healthcare Associated Infections</h2>
      <p class="section-help">Standardized Infection Ratios (SIR). A SIR &lt;&nbsp;1.0 means fewer infections than predicted based on national baseline data.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Measure</th>
              <th>Score (SIR)</th>
              <th>vs. National</th>
            </tr>
          </thead>
          <tbody>
            {hai.map((row: any) => {
              const measureId = row['Measure ID'] || row['HAI Measure ID'] || row['Measure Name'] || '';
              const score = row['Score'] ?? row['SIR'] ?? null;
              const compared = row['Compared to National'] || row['Compared To National'] || '';
              const compColor = compared.includes('Better') ? '#059669' : compared.includes('Worse') ? '#dc2626' : 'inherit';
              return (
                <tr>
                  <td style="font-weight: 500;">{measureId}</td>
                  <td>{score !== null ? (typeof score === 'number' ? score.toFixed(3) : score) : '\u2014'}</td>
                  <td style={`color: ${compColor}; font-weight: ${compared.includes('Better') || compared.includes('Worse') ? '600' : '400'};`}>{compared || '\u2014'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 9. TIMELY & EFFECTIVE CARE                                      -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {timelyCare && timelyCare.length > 0 && (
    <div class="card" id="timely-care">
      <h2>Timely & Effective Care</h2>
      <p class="section-help">Process-of-care measures including ED wait times, treatment timeliness, and preventive care.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Measure</th>
              <th>Score</th>
              <th>Condition</th>
            </tr>
          </thead>
          <tbody>
            {timelyCare.slice(0, 50).map((row: any) => {
              const measureId = row['Measure ID'] || row['Measure Name'] || '';
              const score = row['Score'] ?? null;
              const condition = row['Condition'] || '';
              return (
                <tr>
                  <td style="font-weight: 500;">{measureId}</td>
                  <td>{score !== null ? (typeof score === 'number' ? score.toFixed(1) : score) : '\u2014'}</td>
                  <td>{condition}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      {timelyCare.length > 50 && (
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Showing 50 of {timelyCare.length} measures. Download CSV for full data.
        </p>
      )}
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 10. UNPLANNED HOSPITAL VISITS                                   -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {unplannedVisits && unplannedVisits.length > 0 && (
    <div class="card" id="unplanned-visits">
      <h2>Unplanned Hospital Visits</h2>
      <p class="section-help">Readmission and ED return rates within 30 days of discharge.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Measure</th>
              <th>Score</th>
              <th>vs. National</th>
            </tr>
          </thead>
          <tbody>
            {unplannedVisits.map((row: any) => {
              const measureId = row['Measure ID'] || row['Measure Name'] || '';
              const score = row['Score'] ?? row['Rate'] ?? null;
              const compared = row['Compared to National'] || row['Compared To National'] || '';
              const compColor = compared.includes('Better') ? '#059669' : compared.includes('Worse') ? '#dc2626' : 'inherit';
              return (
                <tr>
                  <td style="font-weight: 500;">{measureId}</td>
                  <td>{score !== null ? (typeof score === 'number' ? score.toFixed(2) : score) : '\u2014'}</td>
                  <td style={`color: ${compColor}; font-weight: ${compared.includes('Better') || compared.includes('Worse') ? '600' : '400'};`}>{compared || '\u2014'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 11. MEDICARE SPENDING PER BENEFICIARY                           -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {mspb && (
    <div class="card" id="mspb">
      <h2>Medicare Spending Per Beneficiary</h2>
      <p class="section-help">MSPB ratio: values &gt;&nbsp;1.0 mean this hospital's episode spending is higher than the national median hospital.</p>
      <div class="metric-grid">
        {Object.entries(mspb).slice(0, 8).map(([key, val]: [string, any]) => {
          if (typeof val !== 'number') return null;
          const isRatio = key.toLowerCase().includes('ratio') || key.toLowerCase().includes('mspb');
          return (
            <div class="metric-card">
              <div class="label">{key.replace(/_/g, ' ')}</div>
              <div class="value" style={isRatio ? `color: ${val > 1 ? '#dc2626' : '#059669'}` : ''}>
                {val.toFixed(2)}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 12. FINANCIAL HEALTH                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {costReport && (
    <div class="card" id="financial">
      <h2>Financial Health <span style="font-size: 0.85rem; color: var(--color-text-muted); font-weight: 400;">(Cost Report{costReport.fiscal_year ? ` — FY ${costReport.fiscal_year}` : ''})</span></h2>

      <div class="metric-grid">
        {costReport.operating_margin != null && (
          <div class="metric-card">
            <div class="label">Operating Margin</div>
            <div class="value" style={`color: ${costReport.operating_margin >= 0 ? '#059669' : '#dc2626'}`}>
              {costReport.operating_margin.toFixed(1)}%
            </div>
            {bmMedian('cost.operating_margin') !== null && (
              <div class="metric-median">Nat'l median: {bmMedian('cost.operating_margin')!.toFixed(1)}%</div>
            )}
          </div>
        )}
        {costReport.occupancy_rate != null && (
          <div class="metric-card">
            <div class="label">Occupancy Rate</div>
            <div class="value">{costReport.occupancy_rate.toFixed(1)}%</div>
            {bmMedian('cost.occupancy_rate') !== null && (
              <div class="metric-median">Nat'l median: {bmMedian('cost.occupancy_rate')!.toFixed(1)}%</div>
            )}
          </div>
        )}
        {costReport.cost_per_discharge != null && (
          <div class="metric-card">
            <div class="label">Cost per Discharge</div>
            <div class="value">${Math.round(costReport.cost_per_discharge).toLocaleString()}</div>
            {bmMedian('cost.cost_per_discharge') !== null && (
              <div class="metric-median">Nat'l median: ${Math.round(bmMedian('cost.cost_per_discharge')!).toLocaleString()}</div>
            )}
          </div>
        )}
        {costReport.current_ratio != null && (
          <div class="metric-card">
            <div class="label">Current Ratio</div>
            <div class="value">{costReport.current_ratio.toFixed(2)}</div>
            {bmMedian('cost.current_ratio') !== null && (
              <div class="metric-median">Nat'l median: {bmMedian('cost.current_ratio')!.toFixed(2)}</div>
            )}
          </div>
        )}
        {costReport.uncompensated_care_pct != null && (
          <div class="metric-card">
            <div class="label">Uncompensated Care</div>
            <div class="value">{costReport.uncompensated_care_pct.toFixed(1)}%</div>
          </div>
        )}
        {costReport.medicare_day_share != null && (
          <div class="metric-card">
            <div class="label">Medicare Day Share</div>
            <div class="value">{costReport.medicare_day_share.toFixed(1)}%</div>
          </div>
        )}
      </div>

      {(costReport.net_patient_revenue != null || costReport.total_costs != null || costReport.net_income != null) && (
        <>
          <h3 style="font-size: 1rem; margin: 1rem 0 0.5rem;">Revenue & Costs</h3>
          <table class="kv-table">
            <tbody>
              {costReport.net_patient_revenue != null && (
                <tr><td>Net Patient Revenue</td><td>${Math.round(costReport.net_patient_revenue).toLocaleString()}</td></tr>
              )}
              {costReport.total_costs != null && (
                <tr><td>Total Costs</td><td>${Math.round(costReport.total_costs).toLocaleString()}</td></tr>
              )}
              {costReport.net_income != null && (
                <tr>
                  <td>Net Income</td>
                  <td style={`color: ${costReport.net_income >= 0 ? '#059669' : '#dc2626'}`}>
                    ${Math.round(costReport.net_income).toLocaleString()}
                  </td>
                </tr>
              )}
              {costReport.total_assets != null && (
                <tr><td>Total Assets</td><td>${Math.round(costReport.total_assets).toLocaleString()}</td></tr>
              )}
              {costReport.total_liabilities != null && (
                <tr><td>Total Liabilities</td><td>${Math.round(costReport.total_liabilities).toLocaleString()}</td></tr>
              )}
              {costReport.fund_balance != null && (
                <tr><td>Fund Balance</td><td>${Math.round(costReport.fund_balance).toLocaleString()}</td></tr>
              )}
            </tbody>
          </table>
        </>
      )}
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 13. RELATED ENTITIES                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {related.length > 0 && (
    <div class="card" id="related">
      <h2>Related Entities</h2>
      <ul class="related-list">
        {related.map((rel: any) => (
          <li>
            <span class={badgeClass(rel.type)}>{rel.type}</span>
            <a href={entityUrl(rel)}>{rel.name}</a>
            {rel.context && <span class="related-context">{rel.context}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ALL DATA                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  {allDataRows.length > 0 && (
    <div class="aco-section" id="all-data">
      <h2>All Data</h2>
      <p class="section-help">
        Every labeled metric surfaced for this hospital, with national medians
        and percentiles where a benchmark is available.
      </p>
      <p style="margin-bottom: 0.75rem;">
        <a href={allDataCsvUri} download={`hospital_${ccn}_all_data.csv`} class="btn">
          Download CSV
        </a>
      </p>
      <details>
        <summary style="cursor: pointer; color: var(--color-primary); margin-bottom: 0.75rem;">
          Show {allDataRows.length.toLocaleString()} rows
        </summary>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Source</th>
                <th>Metric</th>
                <th style="text-align:right;">Value</th>
                <th style="text-align:right;">National Median</th>
                <th>Pctl.</th>
                <th>Raw key</th>
              </tr>
            </thead>
            <tbody>
              {allDataRows.map(r => (
                <tr>
                  <td style="font-size: 0.8rem; color: var(--color-text-muted);">{r.group}</td>
                  <td style="font-weight: 500;">{r.label}</td>
                  <td style="text-align:right; font-variant-numeric:tabular-nums;">{r.value}</td>
                  <td class="bm-col" style="text-align:right;">{r.bmMedian}</td>
                  <td>
                    {r.percentile !== undefined && (
                      <span class={`pctl-badge ${allDataPctlClass(r.percentile)}`}>p{r.percentile}</span>
                    )}
                  </td>
                  <td><code style="font-size: 0.75rem;">{r.rawKey}</code></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- METHODOLOGY / PROVENANCE                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <div class="methodology-stub">
    <strong>Methodology</strong>
    {provenance.length > 0 ? (
      <ul style="list-style: none; padding: 0; margin: 0.5rem 0 0;">
        {provenance.map((p: any) => (
          <li style="margin-bottom: 0.25rem;">
            <strong>{p.dataset_name}</strong>
            {' '}(dataset: <code>{p.dataset_id}</code>, vintage: {p.vintage}, downloaded: {p.download_date})
          </li>
        ))}
      </ul>
    ) : (
      <p>No provenance data available.</p>
    )}
    <p style="margin-top: 0.5rem;">
      <a href="/methodology/">Full methodology &rarr;</a>
    </p>
  </div>

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>

<style>
  /* ── Hospital Overview Grid ────────────────────────────────────── */

  .hosp-overview-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .hosp-overview-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Star Rating Card ──────────────────────────────────────────── */

  .hosp-star-card {
    text-align: center;
    padding: 1.25rem 2rem;
    background: var(--color-surface-alt, #f8fafc);
    border-radius: 12px;
    border: 1px solid var(--color-border);
    min-width: 160px;
  }

  .hosp-star-display {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }

  .hosp-star-number {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .hosp-star-of {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .hosp-star-stars {
    font-size: 1.5rem;
    margin: 0.25rem 0;
  }

  .hosp-star-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* ── Tags ──────────────────────────────────────────────────────── */

  .tag-yes {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    background: #dcfce7;
    color: #059669;
  }

  .tag-no {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    background: #fee2e2;
    color: #dc2626;
  }

  /* ── Hospital Type Context ─────────────────────────────────────── */

  .hosp-type-context {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-alt, #f8fafc);
    border-radius: 8px;
    border-left: 3px solid var(--color-accent, #3b82f6);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .hosp-type-context strong {
    color: var(--color-text);
  }

  /* ── Star Rating Domain Breakdown ──────────────────────────────── */

  .star-domain-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .star-domain-row {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .star-domain-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
