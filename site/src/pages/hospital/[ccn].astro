---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'hospital');
  const paths: Array<{ params: { ccn: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { ccn: manifest.ccn },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { ccn } = Astro.params;

// Extract useful fields
const name = manifest.facility_name;
const rating = manifest.hospital_overall_rating;
const ratingNum = rating && rating !== 'Not Available' ? parseInt(rating) : null;

// Build the CSV data for download
const generalInfo = manifest.data?.general_info || {};
const csvHeaders = Object.keys(generalInfo);
const csvRow = csvHeaders.map((h: string) => `"${(generalInfo[h] || '').replace(/"/g, '""')}"`);
const csvContent = csvHeaders.join(',') + '\n' + csvRow.join(',');
const csvDataUri = `data:text/csv;charset=utf-8,${encodeURIComponent(csvContent)}`;

// Provenance info
const provenance = manifest.provenance?.[0];

// Enrichment data
const readmissions = manifest.data?.readmissions || null;
const vbp = manifest.data?.vbp || null;
const timelyCare = manifest.data?.timely_effective_care || null;
const complications = manifest.data?.complications_deaths || null;
const hcahps = manifest.data?.hcahps || null;
const hai = manifest.data?.hai || null;
const unplannedVisits = manifest.data?.unplanned_visits || null;
const mspb = manifest.data?.mspb || null;
const related = manifest.related || [];

// Friendly measure names for HRRP
const measureLabels: Record<string, string> = {
  'READM-30-HIP-KNEE-HRRP': 'Hip/Knee Replacement',
  'READM-30-CABG-HRRP': 'CABG Surgery',
  'READM-30-AMI-HRRP': 'Acute Myocardial Infarction',
  'READM-30-COPD-HRRP': 'COPD',
  'READM-30-PN-HRRP': 'Pneumonia',
  'READM-30-HF-HRRP': 'Heart Failure',
};

// VBP domain labels
const vbpDomains = [
  { key: 'total_performance_score', label: 'Total Performance Score' },
  { key: 'clinical_outcomes_score', label: 'Clinical Outcomes' },
  { key: 'safety_score', label: 'Safety' },
  { key: 'person_community_score', label: 'Person & Community Engagement' },
  { key: 'efficiency_score', label: 'Efficiency & Cost Reduction' },
];

// Entity URL helpers
function entityUrl(rel: { type: string; id: string }): string {
  if (rel.type === 'county') return `/county/${rel.id}/`;
  if (rel.type === 'hospital') return `/hospital/${rel.id}/`;
  if (rel.type === 'snf') return `/snf/${rel.id}/`;
  if (rel.type === 'aco') return `/aco/${rel.id}/`;
  if (rel.type === 'drug') return `/drug/${rel.id}/`;
  if (rel.type === 'condition') return `/condition/${rel.id}/`;
  if (rel.type === 'drg') return `/drg/${rel.id}/`;
  return '#';
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}
---

<BaseLayout title={name} description={`${name} (CCN: ${ccn}) — Hospital profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-hospital">Hospital</span>
      <h1 style="margin: 0;">{name}</h1>
    </div>
    <p class="subtitle">
      CCN: <code>{ccn}</code> &middot; {manifest.city}, {manifest.state} {manifest.zip_code}
      {manifest.county_name && <span>&middot; {manifest.county_name} County</span>}
    </p>
  </div>

  <div class="actions-bar">
    <div class="mode-toggle" id="mode-toggle">
      <button class="active" data-mode="explore">Explore</button>
      <button data-mode="table">Table</button>
    </div>
    <a href={csvDataUri} download={`hospital_${ccn}_general_info.csv`} class="btn">
      Download CSV
    </a>
    <button class="btn" id="pin-btn" data-entity-type="hospital" data-entity-id={ccn} data-entity-name={name}>
      Pin to Workspace
    </button>
  </div>

  <!-- Explore mode -->
  <div id="explore-view">
    <div class="card">
      <h2>Overview</h2>
      <dl class="kv-grid">
        <dt>Address</dt>
        <dd>{manifest.address}, {manifest.city}, {manifest.state} {manifest.zip_code}</dd>
        <dt>Phone</dt>
        <dd>{manifest.phone_number}</dd>
        <dt>Hospital type</dt>
        <dd>{manifest.hospital_type}</dd>
        <dt>Ownership</dt>
        <dd>{manifest.hospital_ownership}</dd>
        <dt>Emergency services</dt>
        <dd>{manifest.emergency_services}</dd>
        {ratingNum !== null && (
          <>
            <dt>Overall star rating</dt>
            <dd>
              <span class="star-rating">
                {[1,2,3,4,5].map(i => (
                  <span class={i <= ratingNum ? 'star-filled' : 'star-empty'}>&#9733;</span>
                ))}
              </span>
              ({ratingNum}/5)
            </dd>
          </>
        )}
        {ratingNum === null && rating && (
          <>
            <dt>Overall star rating</dt>
            <dd style="color: var(--color-text-muted);">&mdash; {rating}</dd>
          </>
        )}
      </dl>
    </div>

    {readmissions && Object.keys(readmissions).length > 0 && (
      <div class="card">
        <h2>Readmissions (HRRP)</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Condition</th>
                <th>Excess Readmission Ratio</th>
                <th>Predicted Rate</th>
                <th>Expected Rate</th>
              </tr>
            </thead>
            <tbody>
              {Object.entries(readmissions).map(([measure, d]: [string, any]) => (
                <tr>
                  <td style="font-weight: 500;">{measureLabels[measure] || measure}</td>
                  <td style={d.excess_readmission_ratio > 1 ? 'color: var(--color-error);' : 'color: var(--color-accent);'}>
                    {d.excess_readmission_ratio?.toFixed(4) ?? '\u2014'}
                  </td>
                  <td>{d.predicted_readmission_rate?.toFixed(2) ?? '\u2014'}%</td>
                  <td>{d.expected_readmission_rate?.toFixed(2) ?? '\u2014'}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Ratio &gt; 1.0 means higher-than-expected readmissions. Source: Hospital Readmissions Reduction Program.
        </p>
      </div>
    )}

    {vbp && (
      <div class="card">
        <h2>Value-Based Purchasing</h2>
        <div class="metric-grid">
          {vbpDomains.map(({ key, label }) => {
            const val = vbp[key];
            if (val === null || val === undefined) return null;
            return (
              <div class="metric-card">
                <div class="label">{label}</div>
                <div class="value">{typeof val === 'number' ? val.toFixed(1) : val}</div>
              </div>
            );
          })}
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Source: Hospital Value-Based Purchasing Total Performance Score.
        </p>
      </div>
    )}

    {complications && complications.length > 0 && (
      <div class="card">
        <h2>Complications & Deaths</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Measure</th>
                <th>Score</th>
                <th>Compared to National</th>
                <th>Denominator</th>
              </tr>
            </thead>
            <tbody>
              {complications.map((row: any) => {
                const measureId = row['Measure ID'] || row['Measure Name'] || '';
                const score = row['Score'] ?? row['Rate'] ?? '\u2014';
                const compared = row['Compared to National'] || row['Compared To National'] || '';
                const denom = row['Denominator'] ?? row['Number of Patients'] ?? '';
                return (
                  <tr>
                    <td style="font-weight: 500;">{measureId}</td>
                    <td>{typeof score === 'number' ? score.toFixed(2) : score}</td>
                    <td>{compared}</td>
                    <td>{typeof denom === 'number' ? denom.toLocaleString() : denom}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          30-day mortality rates, patient safety indicators, and complication rates. Source: CMS Complications and Deaths.
        </p>
      </div>
    )}

    {hcahps && hcahps.length > 0 && (
      <div class="card">
        <h2>Patient Experience (HCAHPS)</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Measure</th>
                <th>Score</th>
                <th>Star Rating</th>
              </tr>
            </thead>
            <tbody>
              {hcahps.map((row: any) => {
                const measureId = row['HCAHPS Measure ID'] || row['Measure ID'] || '';
                const answer = row['HCAHPS Answer Description'] || row['Patient Survey Star Rating'] || '';
                const pct = row['HCAHPS Answer Percent'] ?? row['Score'] ?? '';
                const star = row['Patient Survey Star Rating'] ?? '';
                return (
                  <tr>
                    <td style="font-weight: 500;">{measureId}{answer ? `: ${answer}` : ''}</td>
                    <td>{typeof pct === 'number' ? `${pct}%` : pct || '\u2014'}</td>
                    <td>{star || '\u2014'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Patient experience survey results. Source: HCAHPS (Hospital Consumer Assessment of Healthcare Providers and Systems).
        </p>
      </div>
    )}

    {hai && hai.length > 0 && (
      <div class="card">
        <h2>Healthcare Associated Infections</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Measure</th>
                <th>Score (SIR)</th>
                <th>Compared to National</th>
              </tr>
            </thead>
            <tbody>
              {hai.map((row: any) => {
                const measureId = row['Measure ID'] || row['HAI Measure ID'] || row['Measure Name'] || '';
                const score = row['Score'] ?? row['SIR'] ?? '\u2014';
                const compared = row['Compared to National'] || row['Compared To National'] || '';
                return (
                  <tr>
                    <td style="font-weight: 500;">{measureId}</td>
                    <td>{typeof score === 'number' ? score.toFixed(3) : score}</td>
                    <td>{compared}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Standardized Infection Ratios (SIR &lt; 1.0 = fewer infections than predicted). Source: CDC NHSN / CMS HAI data.
        </p>
      </div>
    )}

    {timelyCare && timelyCare.length > 0 && (
      <div class="card">
        <h2>Timely & Effective Care</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Measure</th>
                <th>Score</th>
                <th>Condition</th>
              </tr>
            </thead>
            <tbody>
              {timelyCare.slice(0, 30).map((row: any) => {
                const measureId = row['Measure ID'] || row['Measure Name'] || '';
                const score = row['Score'] ?? '\u2014';
                const condition = row['Condition'] || '';
                return (
                  <tr>
                    <td style="font-weight: 500;">{measureId}</td>
                    <td>{typeof score === 'number' ? score.toFixed(1) : score}</td>
                    <td>{condition}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Process-of-care measures including ED wait times, treatment timeliness, and preventive care. Source: CMS Timely and Effective Care.
        </p>
      </div>
    )}

    {unplannedVisits && unplannedVisits.length > 0 && (
      <div class="card">
        <h2>Unplanned Hospital Visits</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Measure</th>
                <th>Score</th>
                <th>Compared to National</th>
              </tr>
            </thead>
            <tbody>
              {unplannedVisits.map((row: any) => {
                const measureId = row['Measure ID'] || row['Measure Name'] || '';
                const score = row['Score'] ?? row['Rate'] ?? '\u2014';
                const compared = row['Compared to National'] || row['Compared To National'] || '';
                return (
                  <tr>
                    <td style="font-weight: 500;">{measureId}</td>
                    <td>{typeof score === 'number' ? score.toFixed(2) : score}</td>
                    <td>{compared}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Readmission and ED return rates within 30 days of discharge. Source: CMS Unplanned Hospital Visits.
        </p>
      </div>
    )}

    {mspb && (
      <div class="card">
        <h2>Medicare Spending Per Beneficiary</h2>
        <div class="metric-grid">
          {Object.entries(mspb).slice(0, 8).map(([key, val]: [string, any]) => {
            if (typeof val !== 'number') return null;
            return (
              <div class="metric-card">
                <div class="label">{key.replace(/_/g, ' ')}</div>
                <div class="value">{val.toFixed(2)}</div>
              </div>
            );
          })}
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          MSPB ratio: values &gt; 1.0 mean higher spending than the national median hospital. Source: CMS MSPB.
        </p>
      </div>
    )}

    {related.length > 0 && (
      <div class="card">
        <h2>Related Entities</h2>
        <ul class="related-list">
          {related.map((rel: any) => (
            <li>
              <span class={badgeClass(rel.type)}>{rel.type}</span>
              <a href={entityUrl(rel)}>{rel.name}</a>
              {rel.context && <span class="related-context">{rel.context}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="methodology-stub">
      <strong>Methodology</strong>
      <p>
        Data source: <strong>{provenance?.dataset_name}</strong>
        (dataset ID: <code>{provenance?.dataset_id}</code>).
        Vintage: {provenance?.vintage}.
        Downloaded: {provenance?.download_date}.
        Rows in source: {provenance?.row_count?.toLocaleString()}.
      </p>
      {manifest.provenance?.length > 1 && (
        <p>
          Additional data sources:
          {manifest.provenance.slice(1).map((p: any) => (
            <span> <strong>{p.dataset_name}</strong> ({p.vintage})</span>
          ))}
        </p>
      )}
      <p>
        <a href="/methodology/">Full methodology &rarr;</a>
      </p>
    </div>
  </div>

  <!-- Table mode -->
  <div id="table-view" style="display: none;">
    <div class="card">
      <h2>Hospital General Information</h2>
      <div style="overflow-x: auto;">
        <table class="data-table" id="data-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(generalInfo).map(([key, value]) => (
              <tr>
                <td style="font-weight: 500;">{key}</td>
                <td>{value as string || '\u2014'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    // Mode toggle
    const toggle = document.getElementById('mode-toggle');
    const exploreView = document.getElementById('explore-view');
    const tableView = document.getElementById('table-view');

    if (toggle && exploreView && tableView) {
      const buttons = toggle.querySelectorAll('button');
      // Restore from localStorage
      const savedMode = localStorage.getItem('caregraph-mode') || 'explore';
      setMode(savedMode);

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const mode = btn.getAttribute('data-mode') || 'explore';
          setMode(mode);
          localStorage.setItem('caregraph-mode', mode);
        });
      });

      function setMode(mode: string) {
        buttons.forEach(b => b.classList.toggle('active', b.getAttribute('data-mode') === mode));
        exploreView!.style.display = mode === 'explore' ? '' : 'none';
        tableView!.style.display = mode === 'table' ? '' : 'none';
      }
    }

    // Simple table sorting
    const table = document.getElementById('data-table') as HTMLTableElement | null;
    if (table) {
      const headers = table.querySelectorAll('th');
      headers.forEach((header, index) => {
        header.addEventListener('click', () => {
          const tbody = table.querySelector('tbody');
          if (!tbody) return;
          const rows = Array.from(tbody.querySelectorAll('tr'));
          const ascending = header.getAttribute('data-sort') !== 'asc';
          header.setAttribute('data-sort', ascending ? 'asc' : 'desc');
          rows.sort((a, b) => {
            const aVal = a.cells[index]?.textContent || '';
            const bVal = b.cells[index]?.textContent || '';
            return ascending ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
          });
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    }
  </script>

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>
