---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import {
  buildAllDataCsv,
  heuristicFormat,
  pctlClass as allDataPctlClass,
  type AllDataRow,
} from '../../config/all-data';

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'snf');
  const paths: Array<{ params: { ccn: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { ccn: manifest.ccn },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { ccn } = Astro.params;

const name = manifest.provider_name;
const providerInfo = manifest.data?.provider_info || {};

// Star ratings
function parseRating(val: string | number | null | undefined): number | null {
  if (val === null || val === undefined || val === '' || val === 'Not Available') return null;
  const n = parseInt(String(val));
  return isNaN(n) ? null : n;
}

const ratings = [
  { label: 'Overall Rating', value: parseRating(manifest.overall_rating) },
  { label: 'Health Inspection', value: parseRating(manifest.health_inspection_rating) },
  { label: 'Quality Measures', value: parseRating(manifest.qm_rating) },
  { label: 'Staffing', value: parseRating(manifest.staffing_rating) },
];

// Provenance info
const provenance = manifest.provenance?.[0];

// Enrichment data
const penalties = manifest.data?.penalties || null;
const deficiencies = manifest.data?.deficiencies || null;
const ownership = manifest.data?.ownership || null;
const costReport = manifest.data?.cost_report || null;

// ── Build "All Data" rows (drives the All Data section + CSV) ──────

const SNF_GROUP_LABELS: Record<string, string> = {
  provider_info: 'Provider Information',
  penalties: 'Penalties',
  deficiencies: 'Deficiencies',
  ownership: 'Ownership',
  cost_report: 'Cost Report',
};

const allDataRows: AllDataRow[] = [];

// Provider info — CMS ships these with human-readable CSV headers already.
for (const [k, v] of Object.entries(providerInfo)) {
  if (v === null || v === undefined) continue;
  const s = String(v).trim();
  allDataRows.push({
    group: SNF_GROUP_LABELS.provider_info,
    rawKey: k,
    label: k,
    value: s === '' ? '\u2014' : s,
    bmMedian: '\u2014',
    percentile: undefined,
  });
}

// Any other data.* subkey — flatten generically.
const handledSnfKeys = new Set(['provider_info']);
for (const [dsKey, ds] of Object.entries(manifest.data || {})) {
  if (handledSnfKeys.has(dsKey)) continue;
  const groupLabel = SNF_GROUP_LABELS[dsKey] || dsKey.replace(/_/g, ' ');
  if (Array.isArray(ds)) {
    for (const row of ds) {
      if (!row || typeof row !== 'object') continue;
      for (const [k, v] of Object.entries(row as Record<string, any>)) {
        if (v === null || v === undefined || v === '') continue;
        allDataRows.push({
          group: groupLabel,
          rawKey: k,
          label: k,
          value: heuristicFormat(v, k),
          bmMedian: '\u2014',
          percentile: undefined,
        });
      }
    }
  } else if (ds && typeof ds === 'object') {
    for (const [k, v] of Object.entries(ds as Record<string, any>)) {
      if (v === null || v === undefined || v === '') continue;
      allDataRows.push({
        group: groupLabel,
        rawKey: k,
        label: k,
        value: heuristicFormat(v, k),
        bmMedian: '\u2014',
        percentile: undefined,
      });
    }
  }
}

allDataRows.sort((a, b) => {
  if (a.group !== b.group) return a.group.localeCompare(b.group);
  return a.label.localeCompare(b.label);
});

const allDataCsvUri = buildAllDataCsv(allDataRows);

// Payer mix percentages
const medicarePct = costReport?.medicare_pct ?? null;
const medicaidPct = costReport?.medicaid_pct ?? null;
const otherPct = (medicarePct != null && medicaidPct != null) ? Math.max(0, 100 - medicarePct - medicaidPct) : null;

// Related entities
const related = manifest.related || [];

// Entity URL helpers
function entityUrl(rel: { type: string; id: string }): string {
  if (rel.type === 'county') return `/county/${rel.id}/`;
  if (rel.type === 'hospital') return `/hospital/${rel.id}/`;
  if (rel.type === 'snf') return `/snf/${rel.id}/`;
  if (rel.type === 'aco') return `/aco/${rel.id}/`;
  if (rel.type === 'drug') return `/drug/${rel.id}/`;
  if (rel.type === 'condition') return `/condition/${rel.id}/`;
  if (rel.type === 'drg') return `/drg/${rel.id}/`;
  return '#';
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}
---

<BaseLayout title={name} description={`${name} (CCN: ${ccn}) — SNF profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-snf">SNF</span>
      <h1 style="margin: 0;">{name}</h1>
    </div>
    <p class="subtitle">
      CCN: <code>{ccn}</code> &middot; {manifest.city}, {manifest.state} {manifest.zip_code}
      {manifest.county_name && <span>&middot; {manifest.county_name} County</span>}
    </p>
  </div>

  <div class="actions-bar">
    <button class="btn" id="pin-btn" data-entity-type="snf" data-entity-id={ccn} data-entity-name={name}>
      Pin to Workspace
    </button>
  </div>

  <div id="explore-view">
    <div class="card">
      <h2>Overview</h2>
      <dl class="kv-grid">
        <dt>Address</dt>
        <dd>{manifest.address}, {manifest.city}, {manifest.state} {manifest.zip_code}</dd>
        <dt>Beds</dt>
        <dd>{manifest.beds}</dd>
        <dt>Average residents/day</dt>
        <dd>{manifest.average_residents_per_day}</dd>
        <dt>Ownership</dt>
        <dd>{manifest.ownership_type}</dd>
        <dt>Provider resides in hospital</dt>
        <dd>{manifest.provider_resides_in_hospital === 'Y' ? 'Yes' : 'No'}</dd>
      </dl>
    </div>

    <div class="card">
      <h2>Ratings</h2>
      <dl class="kv-grid">
        {ratings.map(r => (
          <>
            <dt>{r.label}</dt>
            <dd>
              {r.value !== null ? (
                <>
                  <span class="star-rating">
                    {[1,2,3,4,5].map(i => (
                      <span class={i <= r.value! ? 'star-filled' : 'star-empty'}>&#9733;</span>
                    ))}
                  </span>
                  ({r.value}/5)
                </>
              ) : (
                <span style="color: var(--color-text-muted);">&mdash; Not Available</span>
              )}
            </dd>
          </>
        ))}
      </dl>
    </div>

    {penalties && penalties.length > 0 && (
      <div class="card">
        <h2>Penalties ({penalties.length})</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Fine Amount</th>
              </tr>
            </thead>
            <tbody>
              {penalties.map((p: any) => (
                <tr>
                  <td>{p.penalty_date || '\u2014'}</td>
                  <td>{p.penalty_type || '\u2014'}</td>
                  <td style={p.fine_amount ? 'color: var(--color-error);' : ''}>
                    {p.fine_amount ? `$${p.fine_amount.toLocaleString()}` : '\u2014'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Fines and payment denials in the last 3 years. Source: CMS Nursing Home Penalties.
        </p>
      </div>
    )}

    {deficiencies && deficiencies.length > 0 && (
      <div class="card">
        <h2>Health Deficiencies ({deficiencies.length})</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Tag</th>
                <th>Severity</th>
                <th>Survey Date</th>
                <th>Correction Date</th>
              </tr>
            </thead>
            <tbody>
              {deficiencies.slice(0, 50).map((d: any) => (
                <tr>
                  <td style="font-weight: 500;">{d.tag || '\u2014'}</td>
                  <td>{d.scope_severity || '\u2014'}</td>
                  <td>{d.survey_date || '\u2014'}</td>
                  <td>{d.correction_date || '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {deficiencies.length > 50 && (
          <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
            Showing 50 of {deficiencies.length} citations. Use Table view for full data.
          </p>
        )}
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Health inspection citations from the last 3 years. Severity A-L (L = most severe). Source: CMS Health Deficiencies.
        </p>
      </div>
    )}

    {ownership && ownership.length > 0 && (
      <div class="card">
        <h2>Ownership</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Owner Name</th>
                <th>Type</th>
                <th>Ownership %</th>
              </tr>
            </thead>
            <tbody>
              {ownership.map((o: any) => (
                <tr>
                  <td style="font-weight: 500;">{o.owner_name || '\u2014'}</td>
                  <td>{o.owner_type || '\u2014'}</td>
                  <td>{o.ownership_percentage != null ? `${o.ownership_percentage}%` : '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Corporate ownership chain. Source: CMS Nursing Home Ownership.
        </p>
      </div>
    )}

    {costReport && (
      <div class="card" id="financial-health">
        <h2>Financial Health <span style="font-size: 0.85rem; color: var(--color-text-muted); font-weight: 400;">(FY {costReport.fiscal_year} Cost Report)</span></h2>

        {medicarePct != null && medicaidPct != null && (
          <div style="margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Payer Mix</h3>
            <div class="demo-bar-track" style="height: 1.5rem; display: flex; border-radius: 6px; overflow: hidden;">
              <div class="demo-bar-fill" style={`width: ${medicarePct}%; background: #2563eb;`} title={`Medicare: ${medicarePct.toFixed(1)}%`}></div>
              <div class="demo-bar-fill" style={`width: ${medicaidPct}%; background: #7c3aed;`} title={`Medicaid: ${medicaidPct.toFixed(1)}%`}></div>
              {otherPct != null && otherPct > 0 && (
                <div class="demo-bar-fill" style={`width: ${otherPct.toFixed(1)}%; background: #9ca3af;`} title={`Other: ${otherPct.toFixed(1)}%`}></div>
              )}
            </div>
            <div style="display: flex; gap: 1rem; margin-top: 0.4rem; font-size: 0.8rem;">
              <span><span style="display:inline-block;width:10px;height:10px;background:#2563eb;border-radius:2px;margin-right:4px;"></span>Medicare {medicarePct.toFixed(1)}%</span>
              <span><span style="display:inline-block;width:10px;height:10px;background:#7c3aed;border-radius:2px;margin-right:4px;"></span>Medicaid {medicaidPct.toFixed(1)}%</span>
              {otherPct != null && otherPct > 0 && (
                <span><span style="display:inline-block;width:10px;height:10px;background:#9ca3af;border-radius:2px;margin-right:4px;"></span>Other {otherPct.toFixed(1)}%</span>
              )}
            </div>
          </div>
        )}

        <div class="metric-grid">
          {costReport.operating_margin != null && (
            <div class="metric-card">
              <div class="label">Operating Margin</div>
              <div class="value" style={`color: ${costReport.operating_margin >= 0 ? '#059669' : '#dc2626'}`}>
                {costReport.operating_margin.toFixed(1) + '%'}
              </div>
            </div>
          )}
          {costReport.cost_per_resident_day != null && (
            <div class="metric-card">
              <div class="label">Cost per Resident Day</div>
              <div class="value">{'$' + Math.round(costReport.cost_per_resident_day).toLocaleString()}</div>
            </div>
          )}
          {costReport.occupancy_rate != null && (
            <div class="metric-card">
              <div class="label">Occupancy Rate</div>
              <div class="value">{costReport.occupancy_rate.toFixed(1) + '%'}</div>
            </div>
          )}
        </div>

        <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Source: CMS SNF Cost Report (FY {costReport.fiscal_year}).
        </p>
      </div>
    )}

    {related.length > 0 && (
      <div class="card">
        <h2>Related Entities</h2>
        <ul class="related-list">
          {related.map((rel: any) => (
            <li>
              <span class={badgeClass(rel.type)}>{rel.type}</span>
              <a href={entityUrl(rel)}>{rel.name}</a>
              {rel.context && <span class="related-context">{rel.context}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="methodology-stub">
      <strong>Methodology</strong>
      <p>
        Data source: <strong>{provenance?.dataset_name}</strong>
        (dataset ID: <code>{provenance?.dataset_id}</code>).
        Vintage: {provenance?.vintage}.
        Downloaded: {provenance?.download_date}.
        Rows in source: {provenance?.row_count?.toLocaleString()}.
      </p>
      {manifest.provenance?.length > 1 && (
        <p>
          Additional data sources:
          {manifest.provenance.slice(1).map((p: any) => (
            <span> <strong>{p.dataset_name}</strong> ({p.vintage})</span>
          ))}
        </p>
      )}
      <p>
        <a href="/methodology/">Full methodology &rarr;</a>
      </p>
    </div>
  </div>

  {allDataRows.length > 0 && (
    <div class="aco-section" id="all-data">
      <h2>All Data</h2>
      <p class="section-help">
        Every labeled field shipped for this facility by CMS, with national
        medians and percentiles where a benchmark is available.
      </p>
      <p style="margin-bottom: 0.75rem;">
        <a href={allDataCsvUri} download={`snf_${ccn}_all_data.csv`} class="btn">
          Download CSV
        </a>
      </p>
      <details>
        <summary style="cursor: pointer; color: var(--color-primary); margin-bottom: 0.75rem;">
          Show {allDataRows.length.toLocaleString()} rows
        </summary>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Source</th>
                <th>Metric</th>
                <th style="text-align:right;">Value</th>
                <th style="text-align:right;">National Median</th>
                <th>Pctl.</th>
                <th>Raw key</th>
              </tr>
            </thead>
            <tbody>
              {allDataRows.map(r => (
                <tr>
                  <td style="font-size: 0.8rem; color: var(--color-text-muted);">{r.group}</td>
                  <td style="font-weight: 500;">{r.label}</td>
                  <td style="text-align:right; font-variant-numeric:tabular-nums;">{r.value}</td>
                  <td class="bm-col" style="text-align:right;">{r.bmMedian}</td>
                  <td>
                    {r.percentile !== undefined && (
                      <span class={`pctl-badge ${allDataPctlClass(r.percentile)}`}>p{r.percentile}</span>
                    )}
                  </td>
                  <td><code style="font-size: 0.75rem;">{r.rawKey}</code></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>
    </div>
  )}

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>
