---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'drg');
  const paths: Array<{ params: { code: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { code: manifest.drg_code },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { code } = Astro.params;

const description = manifest.drg_description;
const inpatient = manifest.data?.inpatient || {};
const metrics = inpatient.metrics || {};
const topHospitals = inpatient.top_hospitals || [];
const paymentRange = inpatient.payment_range;

function formatDollar(val: number | null): string {
  if (val == null) return '\u2014';
  return '$' + val.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function formatNumber(val: number | null): string {
  if (val == null) return '\u2014';
  return Math.round(val).toLocaleString();
}

// Build CSV for download
const csvHeaders = ['hospital_ccn', 'hospital_name', 'discharges', 'avg_payment'];
const csvRows = topHospitals.map((h: any) =>
  `"${h.ccn}","${(h.name || '').replace(/"/g, '""')}",${h.discharges},${h.avg_payment}`
);
const csvContent = csvHeaders.join(',') + '\n' + csvRows.join('\n');
const csvDataUri = `data:text/csv;charset=utf-8,${encodeURIComponent(csvContent)}`;

const provenance = manifest.provenance?.[0];
const related = manifest.related || [];

function entityUrl(rel: { type: string; id: string }): string {
  if (rel.type === 'county') return `/county/${rel.id}/`;
  if (rel.type === 'hospital') return `/hospital/${rel.id}/`;
  if (rel.type === 'snf') return `/snf/${rel.id}/`;
  if (rel.type === 'aco') return `/aco/${rel.id}/`;
  if (rel.type === 'drug') return `/drug/${rel.id}/`;
  if (rel.type === 'condition') return `/condition/${rel.id}/`;
  if (rel.type === 'drg') return `/drg/${rel.id}/`;
  return '#';
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}
---

<BaseLayout title={`DRG ${code}`} description={`DRG ${code}: ${description} — DRG profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-drg">DRG</span>
      <h1 style="margin: 0;">{description}</h1>
    </div>
    <p class="subtitle">
      DRG Code: <code>{code}</code>
    </p>
  </div>

  <div class="actions-bar">
    <div class="mode-toggle" id="mode-toggle">
      <button class="active" data-mode="explore">Explore</button>
      <button data-mode="table">Table</button>
    </div>
    <a href={csvDataUri} download={`drg_${code}_hospitals.csv`} class="btn">
      Download CSV
    </a>
    <button class="btn" id="pin-btn" data-entity-type="drg" data-entity-id={code} data-entity-name={`DRG ${code}: ${description}`}>
      Pin to Workspace
    </button>
  </div>

  <!-- Explore mode -->
  <div id="explore-view">
    <div class="card">
      <h2>Key Metrics</h2>
      <div class="metric-grid">
        {metrics.total_discharges && (
          <div class="metric-card">
            <div class="label">{metrics.total_discharges.label}</div>
            <div class="value">{formatNumber(metrics.total_discharges.value)}</div>
          </div>
        )}
        {metrics.avg_medicare_payment && (
          <div class="metric-card">
            <div class="label">{metrics.avg_medicare_payment.label}</div>
            <div class="value">{formatDollar(metrics.avg_medicare_payment.value)}</div>
          </div>
        )}
        {metrics.avg_total_payment && (
          <div class="metric-card">
            <div class="label">{metrics.avg_total_payment.label}</div>
            <div class="value">{formatDollar(metrics.avg_total_payment.value)}</div>
          </div>
        )}
        {metrics.avg_covered_charge && (
          <div class="metric-card">
            <div class="label">{metrics.avg_covered_charge.label}</div>
            <div class="value">{formatDollar(metrics.avg_covered_charge.value)}</div>
          </div>
        )}
        {metrics.hospital_count && (
          <div class="metric-card">
            <div class="label">{metrics.hospital_count.label}</div>
            <div class="value">{formatNumber(metrics.hospital_count.value)}</div>
          </div>
        )}
      </div>
    </div>

    {paymentRange && (
      <div class="card">
        <h2>Payment Range (Avg Medicare Payment)</h2>
        <div class="metric-grid">
          <div class="metric-card">
            <div class="label">Minimum</div>
            <div class="value">{formatDollar(paymentRange.min)}</div>
          </div>
          <div class="metric-card">
            <div class="label">25th Percentile</div>
            <div class="value">{formatDollar(paymentRange.p25)}</div>
          </div>
          <div class="metric-card">
            <div class="label">Median</div>
            <div class="value">{formatDollar(paymentRange.median)}</div>
          </div>
          <div class="metric-card">
            <div class="label">75th Percentile</div>
            <div class="value">{formatDollar(paymentRange.p75)}</div>
          </div>
          <div class="metric-card">
            <div class="label">Maximum</div>
            <div class="value">{formatDollar(paymentRange.max)}</div>
          </div>
        </div>
      </div>
    )}

    {topHospitals.length > 0 && (
      <div class="card">
        <h2>Top {topHospitals.length} Hospitals by Discharges</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Hospital</th>
                <th style="text-align: right;">Discharges</th>
                <th style="text-align: right;">Avg Medicare Payment</th>
              </tr>
            </thead>
            <tbody>
              {topHospitals.map((h: any, i: number) => (
                <tr>
                  <td>{i + 1}</td>
                  <td><a href={`/hospital/${h.ccn}/`}>{h.name}</a></td>
                  <td style="text-align: right;">{formatNumber(h.discharges)}</td>
                  <td style="text-align: right;">{formatDollar(h.avg_payment)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {Object.keys(metrics).length === 0 && (
      <div class="card">
        <p style="color: var(--color-text-muted);">
          No inpatient metrics available for this DRG.
        </p>
      </div>
    )}

    {related.length > 0 && (
      <div class="card">
        <h2>Related Entities</h2>
        <ul class="related-list">
          {related.map((rel: any) => (
            <li>
              <span class={badgeClass(rel.type)}>{rel.type}</span>
              <a href={entityUrl(rel)}>{rel.name}</a>
              {rel.context && <span class="related-context">{rel.context}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="methodology-stub">
      <strong>Methodology</strong>
      <p>
        Data source: <strong>{provenance?.dataset_name}</strong>
        (dataset ID: <code>{provenance?.dataset_id}</code>).
        Vintage: {provenance?.vintage}.
        Downloaded: {provenance?.download_date}.
        Rows in source: {provenance?.row_count?.toLocaleString()}.
      </p>
      <p>
        <em>Medicare Inpatient Hospitals by Provider and Service</em> reports charges and payments
        for hospital inpatient stays by DRG (Diagnosis Related Group). Payment amounts reflect what
        Medicare actually paid, while covered charges are the hospital's list price before adjustments.
      </p>
      <p>
        <a href="/methodology/">Full methodology &rarr;</a>
      </p>
    </div>
  </div>

  <!-- Table mode -->
  <div id="table-view" style="display: none;">
    <div class="card">
      <h2>Top Hospitals for DRG {code}</h2>
      <div style="overflow-x: auto;">
        <table class="data-table" id="data-table">
          <thead>
            <tr>
              <th>CCN</th>
              <th>Hospital Name</th>
              <th style="text-align: right;">Discharges</th>
              <th style="text-align: right;">Avg Medicare Payment</th>
            </tr>
          </thead>
          <tbody>
            {topHospitals.map((h: any) => (
              <tr>
                <td><code>{h.ccn}</code></td>
                <td><a href={`/hospital/${h.ccn}/`}>{h.name}</a></td>
                <td style="text-align: right;">{formatNumber(h.discharges)}</td>
                <td style="text-align: right;">{formatDollar(h.avg_payment)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    // Mode toggle
    const toggle = document.getElementById('mode-toggle');
    const exploreView = document.getElementById('explore-view');
    const tableView = document.getElementById('table-view');

    if (toggle && exploreView && tableView) {
      const buttons = toggle.querySelectorAll('button');
      const savedMode = localStorage.getItem('caregraph-mode') || 'explore';
      setMode(savedMode);

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const mode = btn.getAttribute('data-mode') || 'explore';
          setMode(mode);
          localStorage.setItem('caregraph-mode', mode);
        });
      });

      function setMode(mode: string) {
        buttons.forEach(b => b.classList.toggle('active', b.getAttribute('data-mode') === mode));
        exploreView!.style.display = mode === 'explore' ? '' : 'none';
        tableView!.style.display = mode === 'table' ? '' : 'none';
      }
    }

    // Simple table sorting
    const table = document.getElementById('data-table') as HTMLTableElement | null;
    if (table) {
      const headers = table.querySelectorAll('th');
      headers.forEach((header, index) => {
        header.addEventListener('click', () => {
          const tbody = table.querySelector('tbody');
          if (!tbody) return;
          const rows = Array.from(tbody.querySelectorAll('tr'));
          const ascending = header.getAttribute('data-sort') !== 'asc';
          header.setAttribute('data-sort', ascending ? 'asc' : 'desc');
          rows.sort((a, b) => {
            const aVal = a.cells[index]?.textContent || '';
            const bVal = b.cells[index]?.textContent || '';
            return ascending ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
          });
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    }
  </script>

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>
