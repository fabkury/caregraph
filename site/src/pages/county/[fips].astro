---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'county');
  const paths: Array<{ params: { fips: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { fips: manifest.fips },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { fips } = Astro.params;

const name = manifest.county_name;
const state = manifest.state;
const geoVar = manifest.data?.geographic_variation || {};
const metrics = geoVar.metrics || {};
const rawData = geoVar.raw || {};

// Key metrics to highlight in Explore mode
const highlightMetrics = [
  { key: 'TOT_MDCR_STDZD_PYMT_PC', format: 'dollar' },
  { key: 'TOT_MDCR_PYMT_PC', format: 'dollar' },
  { key: 'BENE_AVG_RISK_SCRE', format: 'decimal' },
  { key: 'BENE_AVG_AGE', format: 'decimal' },
  { key: 'ACUTE_HOSP_READMSN_PCT', format: 'percent' },
  { key: 'ER_VISITS_PER_1000_BENES', format: 'decimal' },
  { key: 'BENE_DUAL_PCT', format: 'percent' },
  { key: 'MA_PRTCPTN_RATE', format: 'percent' },
  { key: 'IP_MDCR_STDZD_PYMT_PC', format: 'dollar' },
  { key: 'SNF_MDCR_STDZD_PYMT_PC', format: 'dollar' },
  { key: 'HH_MDCR_STDZD_PYMT_PC', format: 'dollar' },
  { key: 'HOSPC_MDCR_STDZD_PYMT_PC', format: 'dollar' },
];

function formatValue(val: number, format: string): string {
  if (format === 'dollar') return '$' + val.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  if (format === 'percent') return val.toFixed(1) + '%';
  return val.toFixed(2);
}

// Build CSV for download
const csvHeaders = Object.keys(rawData);
const csvRow = csvHeaders.map((h: string) => `"${(rawData[h] || '').replace(/"/g, '""')}"`);
const csvContent = csvHeaders.join(',') + '\n' + csvRow.join(',');
const csvDataUri = `data:text/csv;charset=utf-8,${encodeURIComponent(csvContent)}`;

const provenance = manifest.provenance?.[0];

// SDOH data
const sdoh = manifest.data?.sdoh || null;

// SDOH measures grouped by domain
const sdohDomains: Array<{ domain: string; measures: Array<{ key: string; label: string }> }> = [
  {
    domain: 'Economic Stability',
    measures: [
      { key: 'pct_poverty', label: 'Poverty Rate' },
      { key: 'median_household_income', label: 'Median Household Income' },
      { key: 'unemployment_rate', label: 'Unemployment Rate' },
    ],
  },
  {
    domain: 'Education & Connectivity',
    measures: [
      { key: 'pct_no_high_school', label: 'No High School Diploma' },
      { key: 'pct_broadband', label: 'Broadband Access' },
      { key: 'pct_no_internet', label: 'No Internet Access' },
    ],
  },
  {
    domain: 'Housing & Demographics',
    measures: [
      { key: 'pct_crowded_housing', label: 'Crowded Housing' },
      { key: 'pct_single_parent', label: 'Single-Parent Households' },
      { key: 'pct_age_65_plus', label: 'Age 65+' },
    ],
  },
];

// Chronic conditions data
const chronicConditions = manifest.data?.chronic_conditions || null;

// Get top 5 costliest conditions
const topCostliest = chronicConditions?.conditions
  ? [...chronicConditions.conditions]
      .filter((c: any) => c.per_capita_spending != null)
      .sort((a: any, b: any) => b.per_capita_spending - a.per_capita_spending)
      .slice(0, 5)
  : [];

// PLACES chronic conditions data
const places = manifest.data?.places || null;
const placesHighlight = [
  'DIABETES', 'OBESITY', 'CHD', 'COPD', 'BPHIGH', 'STROKE',
  'CANCER', 'DEPRESSION', 'CASTHMA', 'ARTHRITIS', 'HIGHCHOL', 'CSMOKING',
];

// Related entities
const related = manifest.related || [];
const relatedCapped = related.slice(0, 20);
const relatedOverflow = related.length - 20;

// Entity URL helpers
function entityUrl(rel: { type: string; id: string }): string {
  if (rel.type === 'county') return `/county/${rel.id}/`;
  if (rel.type === 'hospital') return `/hospital/${rel.id}/`;
  if (rel.type === 'snf') return `/snf/${rel.id}/`;
  if (rel.type === 'aco') return `/aco/${rel.id}/`;
  if (rel.type === 'drug') return `/drug/${rel.id}/`;
  if (rel.type === 'condition') return `/condition/${rel.id}/`;
  if (rel.type === 'drg') return `/drg/${rel.id}/`;
  return '#';
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}
---

<BaseLayout title={`${name}, ${state}`} description={`${name}, ${state} (FIPS: ${fips}) — County profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-county">County</span>
      <h1 style="margin: 0;">{name}, {state}</h1>
    </div>
    <p class="subtitle">
      FIPS: <code>{fips}</code>
    </p>
  </div>

  <div class="actions-bar">
    <div class="mode-toggle" id="mode-toggle">
      <button class="active" data-mode="explore">Explore</button>
      <button data-mode="table">Table</button>
    </div>
    <a href={csvDataUri} download={`county_${fips}_geographic_variation.csv`} class="btn">
      Download CSV
    </a>
    <button class="btn" id="pin-btn" data-entity-type="county" data-entity-id={fips} data-entity-name={`${name}, ${state}`}>
      Pin to Workspace
    </button>
  </div>

  <!-- Explore mode -->
  <div id="explore-view">
    <div class="card">
      <h2>Geographic Variation — Key Metrics</h2>
      <div class="metric-grid">
        {highlightMetrics.map(({ key, format }) => {
          const m = metrics[key];
          if (!m) return null;
          return (
            <div class="metric-card">
              <div class="label">{m.label}</div>
              <div class="value">{formatValue(m.value, format)}</div>
            </div>
          );
        })}
      </div>
    </div>

    {Object.keys(metrics).length === 0 && (
      <div class="card">
        <p style="color: var(--color-text-muted);">
          No Geographic Variation metrics available for this county.
        </p>
      </div>
    )}

    {places && Object.keys(places).length > 0 && (
      <div class="card">
        <h2>Chronic Conditions &amp; Health Indicators (CDC PLACES)</h2>
        <div class="metric-grid">
          {placesHighlight.map(key => {
            const m = places[key];
            if (!m) return null;
            return (
              <div class="metric-card">
                <div class="label">{m.measure}</div>
                <div class="value">{m.value}%</div>
                <div style="font-size: 0.75rem; color: var(--color-text-muted);">
                  CI: {m.low_ci}% &ndash; {m.high_ci}%
                </div>
              </div>
            );
          })}
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Source: CDC PLACES County-Level Data. Values are age-adjusted or crude prevalence estimates.
        </p>
      </div>
    )}

    {sdoh && (
      <div class="card" id="sdoh">
        <h2>Social Determinants of Health</h2>
        <p class="section-help">Community-level social and economic factors that influence health outcomes. Source: AHRQ SDOH Database.</p>

        {sdohDomains.map(({ domain, measures }) => (
          <div style="margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">{domain}</h3>
            <div class="metric-grid">
              {measures.map(({ key, label }) => {
                const val = sdoh[key];
                if (val == null) return null;
                const moe = sdoh[key + '_moe'];
                const isIncome = key === 'median_household_income';
                return (
                  <div class="metric-card">
                    <div class="label">{label}</div>
                    <div class="value">
                      {isIncome ? '$' + Math.round(val).toLocaleString() : val.toFixed(1) + '%'}
                    </div>
                    {moe != null && (
                      <div style="font-size: 0.75rem; color: var(--color-text-muted);">
                        MOE: {isIncome ? '\u00b1$' + Math.round(moe).toLocaleString() : '\u00b1' + moe.toFixed(1) + '%'}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    )}

    {chronicConditions && chronicConditions.conditions && chronicConditions.conditions.length > 0 && (
      <div class="card" id="chronic-conditions">
        <h2>Medicare Chronic Disease Burden</h2>
        <p class="section-help">Prevalence and per-capita spending for chronic conditions among Medicare beneficiaries in this county.</p>

        {topCostliest.length > 0 && (
          <div style="margin-bottom: 1rem;">
            <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Top 5 Costliest Conditions</h3>
            <div class="metric-grid">
              {topCostliest.map((c: any) => (
                <div class="metric-card">
                  <div class="label">{c.condition_name}</div>
                  <div class="value">{'$' + Math.round(c.per_capita_spending).toLocaleString()}</div>
                  <div style="font-size: 0.75rem; color: var(--color-text-muted);">per capita</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Condition</th>
                <th style="text-align: right;">Medicare Prevalence</th>
                <th style="text-align: right;">Per-Capita Spending</th>
              </tr>
            </thead>
            <tbody>
              {chronicConditions.conditions.map((c: any) => {
                const aboveNational = c.national_prevalence != null && c.prevalence != null && c.prevalence > c.national_prevalence;
                return (
                  <tr>
                    <td style="font-weight: 500;">{c.condition_name || '\u2014'}</td>
                    <td style={`text-align: right; ${aboveNational ? 'color: #dc2626; font-weight: 500;' : ''}`}>
                      {c.prevalence != null ? c.prevalence.toFixed(1) + '%' : '\u2014'}
                      {aboveNational && <span title="Above national average"> &#9650;</span>}
                    </td>
                    <td style="text-align: right;">
                      {c.per_capita_spending != null ? '$' + Math.round(c.per_capita_spending).toLocaleString() : '\u2014'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Red values with &#9650; indicate prevalence above the national average. Source: CMS Chronic Conditions ({chronicConditions.year || 'latest'}).
        </p>
      </div>
    )}

    {related.length > 0 && (
      <div class="card">
        <h2>Related Entities</h2>
        <ul class="related-list">
          {relatedCapped.map((rel: any) => (
            <li>
              <span class={badgeClass(rel.type)}>{rel.type}</span>
              <a href={entityUrl(rel)}>{rel.name}</a>
              {rel.context && <span class="related-context">{rel.context}</span>}
            </li>
          ))}
        </ul>
        {relatedOverflow > 0 && (
          <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-top: 0.5rem;">
            and {relatedOverflow} more...
          </p>
        )}
      </div>
    )}

    <div class="methodology-stub">
      <strong>Methodology</strong>
      <p>
        Data source: <strong>{provenance?.dataset_name}</strong>
        (dataset ID: <code>{provenance?.dataset_id}</code>).
        Vintage: {provenance?.vintage}.
        Downloaded: {provenance?.download_date}.
        Rows in source: {provenance?.row_count?.toLocaleString()}.
      </p>
      {manifest.provenance?.length > 1 && (
        <p>
          Additional data sources:
          {manifest.provenance.slice(1).map((p: any) => (
            <span> <strong>{p.dataset_name}</strong> ({p.vintage})</span>
          ))}
        </p>
      )}
      <p>
        <em>Medicare Geographic Variation</em> shows standardized per capita spending,
        utilization, and demographic characteristics for Medicare fee-for-service beneficiaries
        at the county level. Standardized payments remove geographic payment adjustments to
        enable fair comparison across regions.
      </p>
      <p>
        <a href="/methodology/">Full methodology &rarr;</a>
      </p>
    </div>
  </div>

  <!-- Table mode -->
  <div id="table-view" style="display: none;">
    <div class="card">
      <h2>All Geographic Variation Fields</h2>
      <div style="overflow-x: auto;">
        <table class="data-table" id="data-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(rawData).map(([key, value]) => (
              <tr>
                <td style="font-weight: 500;">{key}</td>
                <td>{value as string || '\u2014'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    // Mode toggle
    const toggle = document.getElementById('mode-toggle');
    const exploreView = document.getElementById('explore-view');
    const tableView = document.getElementById('table-view');

    if (toggle && exploreView && tableView) {
      const buttons = toggle.querySelectorAll('button');
      const savedMode = localStorage.getItem('caregraph-mode') || 'explore';
      setMode(savedMode);

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const mode = btn.getAttribute('data-mode') || 'explore';
          setMode(mode);
          localStorage.setItem('caregraph-mode', mode);
        });
      });

      function setMode(mode: string) {
        buttons.forEach(b => b.classList.toggle('active', b.getAttribute('data-mode') === mode));
        exploreView!.style.display = mode === 'explore' ? '' : 'none';
        tableView!.style.display = mode === 'table' ? '' : 'none';
      }
    }

    // Simple table sorting
    const table = document.getElementById('data-table') as HTMLTableElement | null;
    if (table) {
      const headers = table.querySelectorAll('th');
      headers.forEach((header, index) => {
        header.addEventListener('click', () => {
          const tbody = table.querySelector('tbody');
          if (!tbody) return;
          const rows = Array.from(tbody.querySelectorAll('tr'));
          const ascending = header.getAttribute('data-sort') !== 'asc';
          header.setAttribute('data-sort', ascending ? 'asc' : 'desc');
          rows.sort((a, b) => {
            const aVal = a.cells[index]?.textContent || '';
            const bVal = b.cells[index]?.textContent || '';
            return ascending ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
          });
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    }
  </script>

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>
