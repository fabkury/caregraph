---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreTable from '../../components/ExploreTable.astro';
import fs from 'node:fs';
import path from 'node:path';

const indexPath = path.resolve(process.cwd(), 'public', 'explore', 'acos.json');
let count = 0;
if (fs.existsSync(indexPath)) {
  count = JSON.parse(fs.readFileSync(indexPath, 'utf-8')).length;
}
---

<BaseLayout title="ACOs" description="Browse all ACOs on CareGraph">
  <div class="page-header">
    <h1>Accountable Care Organizations</h1>
    <p class="subtitle">{count.toLocaleString()} ACOs</p>
  </div>

  <ExploreTable
    dataUrl="/explore/acos.json"
    linkPattern="/aco/{0}/"
    columns={[
      { label: "Name", type: "link" },
      { label: "ACO ID", type: "code" },
      { label: "State" },
      { label: "Track" },
      { label: "Beneficiaries", type: "number" },
      { label: "Quality Score", type: "number" },
      { label: "Savings Rate", type: "percent" },
    ]}
  />
</BaseLayout>
