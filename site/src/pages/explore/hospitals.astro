---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreTable from '../../components/ExploreTable.astro';
import fs from 'node:fs';
import path from 'node:path';

const indexPath = path.resolve(process.cwd(), 'public', 'explore', 'hospitals.json');
let count = 0;
if (fs.existsSync(indexPath)) {
  count = JSON.parse(fs.readFileSync(indexPath, 'utf-8')).length;
}
---

<BaseLayout title="Hospitals" description="Browse all hospitals on CareGraph">
  <div class="page-header">
    <h1>Hospitals</h1>
    <p class="subtitle">{count.toLocaleString()} hospitals</p>
  </div>

  <ExploreTable
    dataUrl="/explore/hospitals.json"
    linkPattern="/hospital/{0}/"
    columns={[
      { label: "Name", type: "link" },
      { label: "CCN", type: "code" },
      { label: "City" },
      { label: "State" },
      { label: "Type" },
      { label: "Rating", type: "rating" },
    ]}
  />
</BaseLayout>
