---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreTable from '../../components/ExploreTable.astro';
import fs from 'node:fs';
import path from 'node:path';

const indexPath = path.resolve(process.cwd(), 'public', 'explore', 'counties.json');
let count = 0;
if (fs.existsSync(indexPath)) {
  count = JSON.parse(fs.readFileSync(indexPath, 'utf-8')).length;
}
---

<BaseLayout title="Counties" description="Browse all counties on CareGraph">
  <div class="page-header">
    <h1>Counties</h1>
    <p class="subtitle">{count.toLocaleString()} counties</p>
  </div>

  <ExploreTable
    dataUrl="/explore/counties.json"
    linkPattern="/county/{0}/"
    columns={[
      { label: "County", type: "link" },
      { label: "FIPS", type: "code" },
      { label: "State" },
      { label: "Standardized Per Capita Spending", type: "currency" },
      { label: "HCC Risk Score", type: "number" },
      { label: "Readmission Rate", type: "percent" },
    ]}
  />
</BaseLayout>
