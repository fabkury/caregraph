---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreTable from '../../components/ExploreTable.astro';
import fs from 'node:fs';
import path from 'node:path';

const indexPath = path.resolve(process.cwd(), 'public', 'explore', 'snfs.json');
let count = 0;
if (fs.existsSync(indexPath)) {
  count = JSON.parse(fs.readFileSync(indexPath, 'utf-8')).length;
}
---

<BaseLayout title="SNFs" description="Browse all skilled nursing facilities on CareGraph">
  <div class="page-header">
    <h1>Skilled Nursing Facilities</h1>
    <p class="subtitle">{count.toLocaleString()} SNFs</p>
  </div>

  <ExploreTable
    dataUrl="/explore/snfs.json"
    linkPattern="/snf/{0}/"
    columns={[
      { label: "Name", type: "link" },
      { label: "CCN", type: "code" },
      { label: "City" },
      { label: "State" },
      { label: "Beds", type: "number" },
      { label: "Overall Rating", type: "rating" },
    ]}
  />
</BaseLayout>
