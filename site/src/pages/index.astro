---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read the manifest index to find sample entities
const siteDataDir = path.resolve(process.cwd(), '..', 'site_data');
let sampleHospital: any = null;
let sampleCounty: any = null;
let sampleSnf: any = null;
let sampleAco: any = null;
let sampleDrug: any = null;
let sampleCondition: any = null;
let sampleDrg: any = null;
let hospitalCount = 0;
let countyCount = 0;
let snfCount = 0;
let acoCount = 0;
let drugCount = 0;
let conditionCount = 0;
let drgCount = 0;

try {
  const indexPath = path.join(siteDataDir, 'index.json');
  if (fs.existsSync(indexPath)) {
    const index = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
    hospitalCount = index.entities?.hospital?.count ?? 0;
    countyCount = index.entities?.county?.count ?? 0;
    snfCount = index.entities?.snf?.count ?? 0;
    acoCount = index.entities?.aco?.count ?? 0;
    drugCount = index.entities?.drug?.count ?? 0;
    conditionCount = index.entities?.condition?.count ?? 0;
    drgCount = index.entities?.drg?.count ?? 0;
  }

  // Pick a sample hospital (first one alphabetically)
  const hospitalDir = path.join(siteDataDir, 'hospital');
  if (fs.existsSync(hospitalDir)) {
    const files = fs.readdirSync(hospitalDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleHospital = JSON.parse(fs.readFileSync(path.join(hospitalDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample county
  const countyDir = path.join(siteDataDir, 'county');
  if (fs.existsSync(countyDir)) {
    const files = fs.readdirSync(countyDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleCounty = JSON.parse(fs.readFileSync(path.join(countyDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample SNF
  const snfDir = path.join(siteDataDir, 'snf');
  if (fs.existsSync(snfDir)) {
    const files = fs.readdirSync(snfDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleSnf = JSON.parse(fs.readFileSync(path.join(snfDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample ACO
  const acoDir = path.join(siteDataDir, 'aco');
  if (fs.existsSync(acoDir)) {
    const files = fs.readdirSync(acoDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleAco = JSON.parse(fs.readFileSync(path.join(acoDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample Drug
  const drugDir = path.join(siteDataDir, 'drug');
  if (fs.existsSync(drugDir)) {
    const files = fs.readdirSync(drugDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleDrug = JSON.parse(fs.readFileSync(path.join(drugDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample Condition
  const conditionDir = path.join(siteDataDir, 'condition');
  if (fs.existsSync(conditionDir)) {
    const files = fs.readdirSync(conditionDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleCondition = JSON.parse(fs.readFileSync(path.join(conditionDir, files[0]), 'utf-8'));
    }
  }

  // Pick a sample DRG
  const drgDir = path.join(siteDataDir, 'drg');
  if (fs.existsSync(drgDir)) {
    const files = fs.readdirSync(drgDir).filter((f: string) => f.endsWith('.json')).sort();
    if (files.length > 0) {
      sampleDrg = JSON.parse(fs.readFileSync(path.join(drgDir, files[0]), 'utf-8'));
    }
  }
} catch (e) {
  // site_data may not exist yet during initial dev
}

const totalEntities = hospitalCount + countyCount + snfCount + acoCount + drugCount + conditionCount + drgCount;
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>CareGraph</h1>
    <p class="tagline">Public CMS Data</p>
    <p style="max-width: 700px; margin: 0 auto 2rem; color: var(--color-text-muted); font-size: 0.95rem;">
      CareGraph stitches together public CMS datasets and gives you convenient links to access data about entities. Free, no ads, no login.
    </p>
  </section>

  <div class="search-box">
    <input
      type="text"
      class="search-input"
      id="home-search"
      placeholder="Search hospitals, SNFs, counties, ACOs, drugs, conditions, DRGs..."
    />
    <p style="text-align: center; font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
      Press Enter to search {totalEntities.toLocaleString()} entities.
    </p>
  </div>

  <h2 style="text-align: center; margin-bottom: 1rem;">Explore by entity</h2>
  <div class="entity-tiles">
    <a class="entity-tile" href="/explore/hospitals/">Hospitals</a>
    <a class="entity-tile" href="/explore/snfs/">SNFs</a>
    <a class="entity-tile" href="/explore/counties/">Counties</a>
    <a class="entity-tile" href="/explore/acos/">ACOs</a>
    <a class="entity-tile" href="/explore/drugs/">Drugs</a>
    <a class="entity-tile" href="/explore/conditions/">Conditions</a>
    <a class="entity-tile" href="/explore/drgs/">DRGs</a>
    <span class="entity-tile" style="opacity: 0.5; cursor: default;" title="Coming soon">Clinicians</span>
  </div>

  {(sampleHospital || sampleCounty || sampleSnf || sampleAco || sampleDrug || sampleCondition || sampleDrg) && (
    <div class="card" style="margin-top: 2rem;">
      <h2>Sample pages</h2>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem;">
        {hospitalCount.toLocaleString()} hospitals, {snfCount.toLocaleString()} SNFs,
        {countyCount.toLocaleString()} counties, {acoCount.toLocaleString()} ACOs,
        {drugCount.toLocaleString()} drugs, {conditionCount.toLocaleString()} conditions,
        and {drgCount.toLocaleString()} DRGs loaded.
      </p>
      <ul style="list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {sampleHospital && (
          <li>
            <a href={`/hospital/${sampleHospital.ccn}/`} class="btn btn-primary">
              {sampleHospital.facility_name} ({sampleHospital.ccn})
            </a>
          </li>
        )}
        {sampleCounty && (
          <li>
            <a href={`/county/${sampleCounty.fips}/`} class="btn btn-primary">
              {sampleCounty.county_name}, {sampleCounty.state} ({sampleCounty.fips})
            </a>
          </li>
        )}
        {sampleSnf && (
          <li>
            <a href={`/snf/${sampleSnf.ccn}/`} class="btn btn-primary">
              {sampleSnf.provider_name} ({sampleSnf.ccn})
            </a>
          </li>
        )}
        {sampleAco && (
          <li>
            <a href={`/aco/${sampleAco.aco_id}/`} class="btn btn-primary">
              {sampleAco.aco_name} ({sampleAco.aco_id})
            </a>
          </li>
        )}
        {sampleDrug && (
          <li>
            <a href={`/drug/${sampleDrug.drug_id}/`} class="btn btn-primary">
              {sampleDrug.generic_name} ({sampleDrug.drug_id})
            </a>
          </li>
        )}
        {sampleCondition && (
          <li>
            <a href={`/condition/${sampleCondition.condition_id}/`} class="btn btn-primary">
              {sampleCondition.condition_name} ({sampleCondition.condition_id})
            </a>
          </li>
        )}
        {sampleDrg && (
          <li>
            <a href={`/drg/${sampleDrg.drg_code}/`} class="btn btn-primary">
              DRG {sampleDrg.drg_code}: {sampleDrg.drg_description?.slice(0, 50)}
            </a>
          </li>
        )}
      </ul>
    </div>
  )}

  <div class="card" style="margin-top: 1rem;">
    <h2>Data freshness</h2>
    <p style="font-size: 0.9rem; color: var(--color-text-muted);">
      Current data sources: Hospital General Information, Hospital Readmissions Reduction Program,
      Hospital Value-Based Purchasing, Nursing Home Provider Info,
      MSSP ACO Performance, Medicare Geographic Variation by County, CDC PLACES County-Level Data,
      Medicare Part D Spending by Drug, Medicare Part B Spending by Drug, Medicare Part B Discarded Drug Units,
      Medicare Inpatient Hospitals by Provider and Service (DRG).
      Last ETL run: {new Date().toISOString().slice(0, 10)}.
      <a href="#">Full vintage table (Methodology Hub) &rarr;</a>
    </p>
  </div>

  <p style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--color-text-muted);">
    Source code:
    <a href="https://github.com/fabkury/caregraph" target="_blank" rel="noopener">github.com/fabkury/caregraph</a>
    &middot; MIT License
  </p>

  <script>
    const searchInput = document.getElementById('home-search') as HTMLInputElement | null;
    if (searchInput) {
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const q = searchInput.value.trim();
          if (q) {
            window.location.href = `/search?q=${encodeURIComponent(q)}`;
          }
        }
      });
    }
  </script>
</BaseLayout>
