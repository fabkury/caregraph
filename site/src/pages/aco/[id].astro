---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import {
  ACO_SECTIONS, QUALITY_FLAGS, DEMOG_RISK_PIVOT, RISK_WEIGHTS,
  MULTI_PATHWAY_MEASURES, getCoveredKeys,
  type FieldDef, type FieldFormat, type PivotTableDef, type Section,
} from '../../config/aco-fields';
import {
  buildAllDataCsv,
  pctlClass as allDataPctlClass,
  type AllDataRow,
} from '../../config/all-data';

// ── Load benchmark and peer cohort data (shared across all ACO pages) ──

const benchmarksPath = path.resolve(process.cwd(), '..', 'site_data', 'aco_benchmarks.json');
const peersPath = path.resolve(process.cwd(), '..', 'site_data', 'aco_peer_cohorts.json');

let benchmarkData: any = null;
let peerData: any = null;
try { benchmarkData = JSON.parse(fs.readFileSync(benchmarksPath, 'utf-8')); } catch {}
try { peerData = JSON.parse(fs.readFileSync(peersPath, 'utf-8')); } catch {}

export function getStaticPaths() {
  const siteDataDir = path.resolve(process.cwd(), '..', 'site_data', 'aco');
  const paths: Array<{ params: { id: string }; props: { manifest: any } }> = [];

  if (!fs.existsSync(siteDataDir)) return paths;

  const files = fs.readdirSync(siteDataDir).filter((f: string) => f.endsWith('.json'));
  for (const file of files) {
    const manifest = JSON.parse(fs.readFileSync(path.join(siteDataDir, file), 'utf-8'));
    paths.push({
      params: { id: manifest.aco_id },
      props: { manifest },
    });
  }

  return paths;
}

const { manifest } = Astro.props;
const { id } = Astro.params;

const name = manifest.aco_name;
const track = manifest.current_track;
const msspMetrics = manifest.data?.mssp_performance?.metrics || {};
const rawData: Record<string, string> = manifest.data?.mssp_performance?.raw || {};
const participants = manifest.data?.participants || null;
const snfAffiliates = manifest.data?.snf_affiliates || null;

// ── Benchmark helpers ────────────────────────────────────────────────

const bm = benchmarkData?.benchmarks || {};
const acoRanks: Record<string, number> = benchmarkData?.aco_ranks?.[id as string] || {};
const spendCompMedians: Record<string, number> = benchmarkData?.spending_composition_medians || {};

const peerCohort = peerData?.cohorts?.[id as string] || null;
const peerMedians: Record<string, number> = peerCohort?.peer_medians || {};
const peerDesc: string = peerCohort?.cohort_description || '';
const peerIds: string[] = peerCohort?.peer_ids || [];

function bmMedian(field: string): number | null {
  return bm[field]?.p50 ?? null;
}

function peerMed(field: string): number | null {
  return peerMedians[field] ?? null;
}

function pctlBadge(field: string, inverted = false): string {
  const p = acoRanks[field];
  if (p === undefined) return '';
  return `p${p}`;
}

function pctlClass(field: string, inverted = false): string {
  const p = acoRanks[field];
  if (p === undefined) return '';
  const prefix = inverted ? 'pctl-inv' : 'pctl';
  if (p <= 25) return `${prefix}-low`;
  if (p >= 75) return `${prefix}-high`;
  return `${prefix}-mid`;
}

function fmtBm(val: number | null, format: FieldFormat): string {
  if (val === null || val === undefined) return '\u2014';
  return fmtRaw(String(val), format);
}

// Key metrics to highlight (Explore view)
const highlightMetrics = [
  { key: 'N_AB', format: 'integer' as const },
  { key: 'Sav_rate', format: 'percent' as const },
  { key: 'QualScore', format: 'decimal' as const },
  { key: 'Per_Capita_Exp_TOTAL_PY', format: 'dollar' as const },
  { key: 'GenSaveLoss', format: 'dollar' as const },
  { key: 'EarnSaveLoss', format: 'dollar' as const },
  { key: 'UpdatedBnchmk', format: 'dollar' as const },
];

function formatValue(val: number, format: string): string {
  if (format === 'dollar') return '$' + val.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  if (format === 'percent') return val.toFixed(2) + '%';
  if (format === 'integer') return Math.round(val).toLocaleString();
  return val.toFixed(2);
}

// ── Formatting for structured Table view ──────────────────────────��──

function fmtRaw(val: string | undefined, format: FieldFormat): string {
  if (val === undefined || val === '' || val === null) return '\u2014';
  if (val === '*') return val; // handled by template with suppressed styling
  if (val === '-') return val; // handled by template with not-reported styling
  const s = String(val).trim();
  if (s === '' || s === '.' || s === 'N/A') return '\u2014';

  const num = parseFloat(s.replace(/[$,%]/g, ''));

  switch (format) {
    case 'dollar':
      return isNaN(num) ? s : '$' + Math.round(num).toLocaleString();
    case 'dollar_agg':
      return isNaN(num) ? s : '$' + Math.round(num).toLocaleString();
    case 'percent':
      return isNaN(num) ? s : num.toFixed(2) + '%';
    case 'decimal3':
      return isNaN(num) ? s : num.toFixed(3);
    case 'decimal2':
      return isNaN(num) ? s : num.toFixed(2);
    case 'integer':
      return isNaN(num) ? s : Math.round(num).toLocaleString();
    case 'rate':
      return isNaN(num) ? s : Math.round(num).toLocaleString();
    case 'boolean':
      if (s === '1') return '\u2713';
      if (s === '0') return '\u2717';
      return s;
    case 'date':
    case 'text':
    default:
      return s;
  }
}

function isSuppressed(val: string | undefined): boolean {
  return val === '*';
}

function isNotReported(val: string | undefined): boolean {
  return val === '-' || val === undefined || val === '';
}

// Trend arrow for pivot tables: compare first available period to last
function trendArrow(first: string | undefined, last: string | undefined): string {
  if (!first || !last || first === '*' || last === '*' || first === '-' || last === '-') return '';
  const a = parseFloat(first);
  const b = parseFloat(last);
  if (isNaN(a) || isNaN(b)) return '';
  const pctChange = ((b - a) / Math.abs(a)) * 100;
  if (pctChange > 3) return '\u2191';  // ↑
  if (pctChange < -3) return '\u2193'; // ↓
  return '\u2192'; // →
}

function trendClass(first: string | undefined, last: string | undefined, lowerIsBetter = false): string {
  const arrow = trendArrow(first, last);
  if (!arrow) return '';
  // For cost/risk metrics: up = bad, down = good
  if (arrow === '\u2191') return lowerIsBetter ? 'trend-down' : 'trend-up';
  if (arrow === '\u2193') return lowerIsBetter ? 'trend-up' : 'trend-down';
  return 'trend-flat';
}

// ── Demographics computation ─────────────────────────��───────────────

const totalBen = parseInt(rawData.N_AB || '0', 10) || 1;

function pct(key: string): string {
  const n = parseInt(rawData[key] || '0', 10);
  if (!n || isNaN(n)) return '0.0';
  return ((n / totalBen) * 100).toFixed(1);
}

function pctNum(key: string): number {
  const n = parseInt(rawData[key] || '0', 10);
  if (!n || isNaN(n)) return 0;
  return (n / totalBen) * 100;
}

const ageGroups = [
  { key: 'N_Ben_Age_0_64',   label: 'Age 0\u201364' },
  { key: 'N_Ben_Age_65_74',  label: 'Age 65\u201374' },
  { key: 'N_Ben_Age_75_84',  label: 'Age 75\u201384' },
  { key: 'N_Ben_Age_85plus', label: 'Age 85+' },
];

const genderGroups = [
  { key: 'N_Ben_Female', label: 'Female' },
  { key: 'N_Ben_Male',   label: 'Male' },
];

const raceGroups = [
  { key: 'N_Ben_Race_White',   label: 'White' },
  { key: 'N_Ben_Race_Black',   label: 'Black' },
  { key: 'N_Ben_Race_Hisp',    label: 'Hispanic' },
  { key: 'N_Ben_Race_Asian',   label: 'Asian' },
  { key: 'N_Ben_Race_Native',  label: 'Native American' },
  { key: 'N_Ben_Race_Other',   label: 'Other' },
  { key: 'N_Ben_Race_Unknown', label: 'Unknown' },
];

// ── Waterfall steps ──────────────────────────────────────────────────

interface WaterfallStep {
  num: string;
  label: string;
  value: string;
  cssClass?: string;
  dividerAfter?: boolean;
  bmKey?: string;
  bmFmt?: FieldFormat;
}

function buildWaterfall(): WaterfallStep[] {
  const steps: WaterfallStep[] = [];
  const r = rawData;

  steps.push({ num: '1', label: 'Assigned Beneficiaries',              value: fmtRaw(r.N_AB, 'integer'), bmKey: 'N_AB', bmFmt: 'integer' });
  steps.push({ num: '2', label: 'Historical Benchmark (per capita)',    value: fmtRaw(r.HistBnchmk, 'dollar'), bmKey: 'HistBnchmk' });
  steps.push({ num: '3', label: 'Regional Adjustment',                 value: r.RegAdj ? '+' + fmtRaw(r.RegAdj, 'dollar') : '\u2014' });
  steps.push({ num: '4', label: 'Prior Savings Adjustment',            value: r.PriorSavAdj ? '+' + fmtRaw(r.PriorSavAdj, 'dollar') : '\u2014' });
  steps.push({ num: '5', label: 'Adjustment Category',                 value: r.FinalAdjCat || '\u2014' });
  steps.push({ num: '6', label: 'Updated Benchmark (per capita)',      value: fmtRaw(r.UpdatedBnchmk, 'dollar'), cssClass: 'step-result', dividerAfter: true, bmKey: 'UpdatedBnchmk' });

  steps.push({ num: '7', label: 'Total Benchmark (all beneficiaries)', value: fmtRaw(r.ABtotBnchmk, 'dollar_agg') });
  steps.push({ num: '8', label: 'Total Expenditure (all beneficiaries)', value: fmtRaw(r.ABtotExp, 'dollar_agg') });
  steps.push({ num: '9', label: 'Per Capita Expenditure (PY)',         value: fmtRaw(r.Per_Capita_Exp_TOTAL_PY, 'dollar'), bmKey: 'Per_Capita_Exp_TOTAL_PY' });

  const genSL = parseFloat(r.GenSaveLoss || '0');
  const genClass = genSL > 0 ? 'step-positive' : genSL < 0 ? 'step-negative' : '';
  steps.push({ num: '10', label: 'Generated Savings / Losses',         value: fmtRaw(r.GenSaveLoss, 'dollar_agg'), cssClass: `step-result ${genClass}`.trim(), dividerAfter: true, bmKey: 'GenSaveLoss', bmFmt: 'dollar_agg' });

  steps.push({ num: '11', label: 'Savings Rate',                       value: fmtRaw(r.Sav_rate, 'percent'), bmKey: 'Sav_rate', bmFmt: 'percent' });
  steps.push({ num: '12', label: 'Minimum Savings Rate (threshold)',    value: fmtRaw(r.MinSavPerc, 'percent') });
  steps.push({ num: '13', label: 'Guardrail Applied',                  value: r.Guardrail === '1' ? 'Yes' : r.Guardrail === '0' ? 'No' : '\u2014' });
  steps.push({ num: '14', label: 'Final Shared Savings Rate',          value: fmtRaw(r.FinalShareRate, 'percent') });
  steps.push({ num: '15', label: 'Final Shared Loss Rate',             value: fmtRaw(r.FinalLossRate, 'percent') });

  const earnSL = parseFloat(r.EarnSaveLoss || '0');
  const earnClass = earnSL > 0 ? 'step-positive' : earnSL < 0 ? 'step-negative' : '';
  steps.push({ num: '16', label: 'Earned Savings / Losses',            value: fmtRaw(r.EarnSaveLoss, 'dollar_agg'), cssClass: `step-result ${earnClass}`.trim(), dividerAfter: true, bmKey: 'EarnSaveLoss', bmFmt: 'dollar_agg' });

  steps.push({ num: '', label: 'Revenue-to-Expense Category',          value: r.Rev_Exp_Cat || '\u2014' });

  // AIP section (only if applicable)
  if (r.AIP === '1') {
    steps.push({ num: '', label: 'Advance Investment Payment',           value: 'Yes' });
    steps.push({ num: '', label: 'AIP Balance',                          value: fmtRaw(r.AIPBalance, 'dollar_agg') });
    steps.push({ num: '', label: 'AIP Recouped',                         value: fmtRaw(r.AIPRecoup, 'dollar_agg') });
    steps.push({ num: '', label: 'AIP Owed',                             value: fmtRaw(r.AIPOwe, 'dollar_agg') });
  }

  return steps;
}

const waterfallSteps = buildWaterfall();

// ── Quality measures: collapse multi-pathway ─────────────────────────

interface QualityRow {
  label: string;
  value: string;
  lowerIsBetter?: boolean;
  help?: string;
  isMultiPathway?: boolean;
  pathways?: { label: string; value: string }[];
  bmKey?: string;
}

function buildQualityRows(): QualityRow[] {
  const rows: QualityRow[] = [];

  // Composite score
  const qs = rawData.QualScore;
  if (qs && qs !== '-' && qs !== '*') {
    rows.push({ label: 'Overall Quality Score (Composite)', value: fmtRaw(qs, 'decimal2'), bmKey: 'QualScore' });
  }

  // Standalone measures
  rows.push({ label: 'All-Cause Unplanned Admissions (risk-adjusted rate)', value: fmtRaw(rawData.Measure_479, 'decimal2'), lowerIsBetter: true, help: 'Risk-standardized rate. Lower indicates better care coordination.', bmKey: 'Measure_479' });
  rows.push({ label: 'Risk-Standardized All-Condition Readmission Rate', value: fmtRaw(rawData.Measure_484, 'decimal2'), lowerIsBetter: true, help: 'Unplanned readmissions within 30 days. Lower is better.', bmKey: 'Measure_484' });
  rows.push({ label: 'Falls: Screening for Future Fall Risk', value: fmtRaw(rawData.QualityID_318, 'decimal2'), bmKey: 'QualityID_318' });
  rows.push({ label: 'Influenza Immunization', value: fmtRaw(rawData.QualityID_110, 'decimal2'), bmKey: 'QualityID_110' });
  rows.push({ label: 'Tobacco Use: Screening & Cessation Intervention', value: fmtRaw(rawData.QualityID_226, 'decimal2'), bmKey: 'QualityID_226' });
  rows.push({ label: 'Colorectal Cancer Screening', value: fmtRaw(rawData.QualityID_113, 'decimal2'), bmKey: 'QualityID_113' });
  rows.push({ label: 'Breast Cancer Screening', value: fmtRaw(rawData.QualityID_112, 'decimal2'), bmKey: 'QualityID_112' });
  rows.push({ label: 'Statin Therapy for CVD Prevention', value: fmtRaw(rawData.QualityID_438, 'decimal2'), bmKey: 'QualityID_438' });
  rows.push({ label: 'Depression Remission at 12 Months', value: fmtRaw(rawData.QualityID_370, 'decimal2'), bmKey: 'QualityID_370' });

  // Multi-pathway measures: show reported value, collapse unreported
  for (const mp of MULTI_PATHWAY_MEASURES) {
    const pathways = mp.pathways.map(pw => ({
      label: pw.label,
      value: fmtRaw(rawData[`QualityID_${mp.measureId}_${pw.suffix}`], 'decimal2'),
    }));
    const reported = pathways.find(p => p.value !== '\u2014' && p.value !== '-');
    // Use the WI variant for benchmark lookup (most common reporting pathway)
    const bmKeyForMp = `QualityID_${mp.measureId}_WI`;
    rows.push({
      label: mp.label,
      value: reported ? reported.value : '\u2014',
      lowerIsBetter: mp.lowerIsBetter,
      isMultiPathway: true,
      pathways,
      bmKey: bmKeyForMp,
    });
  }

  return rows;
}

const qualityRows = buildQualityRows();

// ── Uncovered fields (fallback "Other Fields" section) ───────────────

const coveredKeys = getCoveredKeys();
const uncoveredEntries = Object.entries(rawData).filter(([key]) => !coveredKeys.has(key));

// ── Build "All Data" rows (drives the All Data section + CSV) ──────

// Collect all known raw-key → label mappings from the ACO field config.
const rawLabelByKey = new Map<string, { label: string; format: FieldFormat; group: string }>();

for (const section of ACO_SECTIONS) {
  if (section.fields) {
    for (const f of section.fields) {
      rawLabelByKey.set(f.key, { label: f.label, format: f.format, group: section.title });
    }
  }
  if (section.pivot) {
    const { fieldPrefix, segments, periods, format } = section.pivot;
    for (const seg of segments) {
      for (const per of periods) {
        const key = `${fieldPrefix}${seg.code}_${per.code}`;
        rawLabelByKey.set(key, {
          label: `${seg.label} (${per.label})`,
          format,
          group: section.title,
        });
      }
    }
  }
}
for (const seg of DEMOG_RISK_PIVOT.segments) {
  for (const per of DEMOG_RISK_PIVOT.periods) {
    const key = `${DEMOG_RISK_PIVOT.fieldPrefix}${seg.code}_${per.code}`;
    rawLabelByKey.set(key, {
      label: `${seg.label} (${per.label})`,
      format: DEMOG_RISK_PIVOT.format,
      group: 'Demographic Risk Scores',
    });
  }
}
for (const w of RISK_WEIGHTS) {
  rawLabelByKey.set(w.key, { label: w.label, format: w.format, group: 'Risk Redistribution Weights' });
}
for (const flag of QUALITY_FLAGS) {
  rawLabelByKey.set(flag.key, { label: flag.label, format: 'boolean', group: 'Quality Reporting Flags' });
}
rawLabelByKey.set('ACO_ID', { label: 'ACO ID', format: 'text', group: 'Program Structure' });
rawLabelByKey.set('ACO_Name', { label: 'ACO Name', format: 'text', group: 'Program Structure' });

const allDataRows: AllDataRow[] = [];

for (const [key, val] of Object.entries(rawData)) {
  if (val === null || val === undefined) continue;
  const s = String(val).trim();
  if (s === '') continue;
  const meta = rawLabelByKey.get(key);
  const group = meta?.group || 'Other Raw Fields';
  const label = meta?.label || key;
  const format = meta?.format || 'text';
  const display = fmtRaw(s, format);
  const bmEntry = bm[key];
  const p = acoRanks[key];
  allDataRows.push({
    group,
    rawKey: key,
    label,
    value: display,
    bmMedian: bmEntry && typeof bmEntry.p50 === 'number' ? fmtRaw(String(bmEntry.p50), format) : '\u2014',
    percentile: typeof p === 'number' ? p : undefined,
  });
}

allDataRows.sort((a, b) => {
  if (a.group !== b.group) return a.group.localeCompare(b.group);
  return a.label.localeCompare(b.label);
});

const allDataCsvUri = buildAllDataCsv(allDataRows);

const provenance = manifest.provenance?.[0];

// Related entities
const related = manifest.related || [];

function entityUrl(rel: { type: string; id: string }): string {
  if (rel.type === 'county') return `/county/${rel.id}/`;
  if (rel.type === 'hospital') return `/hospital/${rel.id}/`;
  if (rel.type === 'snf') return `/snf/${rel.id}/`;
  if (rel.type === 'aco') return `/aco/${rel.id}/`;
  if (rel.type === 'drug') return `/drug/${rel.id}/`;
  if (rel.type === 'condition') return `/condition/${rel.id}/`;
  if (rel.type === 'drg') return `/drg/${rel.id}/`;
  return '#';
}

function badgeClass(type: string): string {
  return `badge badge-${type}`;
}
---

<BaseLayout title={name} description={`${name} (ACO ID: ${id}) — ACO profile on CareGraph`}>
  <div class="page-header">
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <span class="badge badge-aco">ACO</span>
      <h1 style="margin: 0;">{name}</h1>
    </div>
    <p class="subtitle">
      ACO ID: <code>{id}</code>
      {track && <span>&middot; Track: {track}</span>}
      {manifest.state && <span>&middot; {manifest.state}</span>}
    </p>
  </div>

  <div class="actions-bar">
    <button class="btn" id="pin-btn" data-entity-type="aco" data-entity-id={id} data-entity-name={name}>
      Pin to Workspace
    </button>
  </div>

  <!-- Key Metrics summary -->
  {Object.keys(msspMetrics).length > 0 && (
    <div class="card">
      <h2>MSSP Performance — Key Metrics</h2>
      <div class="metric-grid">
        {highlightMetrics.map(({ key, format }) => {
          const m = msspMetrics[key];
          if (!m) return null;
          return (
            <div class="metric-card">
              <div class="label">{m.label}</div>
              <div class="value">
                {formatValue(m.value, format)}
                {pctlBadge(key) && <span class={`pctl-badge ${pctlClass(key)}`}>{pctlBadge(key)}</span>}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Section navigation -->
  <nav class="section-nav" aria-label="Data sections">
    {ACO_SECTIONS.map(s => (
      <a href={`#${s.id}`}>{s.title}</a>
    ))}
    {participants && participants.length > 0 && <a href="#network-participants">Participants</a>}
    {snfAffiliates && snfAffiliates.length > 0 && <a href="#snf-affiliates">SNF Affiliates</a>}
    {peerCohort && <a href="#peer-cohort">Peer Cohort</a>}
    {allDataRows.length > 0 && <a href="#all-data">All Data</a>}
  </nav>

  {/* Benchmark legend */}
  <div class="benchmark-legend">
    <span class="benchmark-legend-item">
      <span class="benchmark-legend-swatch" style="background: #fee2e2;"></span> Bottom quartile
    </span>
    <span class="benchmark-legend-item">
      <span class="benchmark-legend-swatch" style="background: #fef9c3;"></span> Middle
    </span>
    <span class="benchmark-legend-item">
      <span class="benchmark-legend-swatch" style="background: #dcfce7;"></span> Top quartile
    </span>
    <span class="benchmark-legend-item" style="color: var(--color-text-muted);">
      MSSP median shown in gray &middot; Peer median in blue
    </span>
  </div>

    <!-- 1. Program Structure -->
    {(() => {
      const sec = ACO_SECTIONS.find(s => s.id === 'program-structure')!;
      return (
        <section class="aco-section" id={sec.id}>
          <a href="#main-content" class="section-back">Back to top</a>
          <h2>{sec.title}</h2>
          <table class="kv-table">
            <tbody>
              {sec.fields!.map(f => (
                <tr>
                  <td>
                    {f.label}
                    {f.help && <span class="help-tip" title={f.help}>?</span>}
                  </td>
                  <td>
                    {isSuppressed(rawData[f.key])
                      ? <span class="val-suppressed" title="Value suppressed by CMS to protect beneficiary privacy (cell size <11).">*</span>
                      : isNotReported(rawData[f.key])
                        ? <span class="val-not-reported">{'\u2014'}</span>
                        : fmtRaw(rawData[f.key], f.format)
                    }
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      );
    })()}

    <!-- 2. Financial Performance — Savings Waterfall -->
    <section class="aco-section" id="financial-performance">
      <a href="#main-content" class="section-back">Back to top</a>
      <h2>Financial Performance</h2>
      <p class="section-help">Step-by-step savings calculation from historical benchmark to earned savings/losses.</p>
      <div style="overflow-x: auto;">
        <table class="waterfall-table">
          <thead>
            <tr>
              <th>Step</th>
              <th>Description</th>
              <th>Value</th>
              <th class="bm-col">MSSP Median</th>
              {peerCohort && <th class="peer-col">Peer Median</th>}
            </tr>
          </thead>
          <tbody>
            {waterfallSteps.map(step => (
              <>
                <tr class={step.cssClass || ''}>
                  <td>{step.num}</td>
                  <td>{step.label}</td>
                  <td>
                    {step.value}
                    {step.bmKey && pctlBadge(step.bmKey) && (
                      <span class={`pctl-badge ${pctlClass(step.bmKey)}`}>{pctlBadge(step.bmKey)}</span>
                    )}
                  </td>
                  <td class="bm-col">{step.bmKey ? fmtBm(bmMedian(step.bmKey), step.bmFmt || 'dollar') : ''}</td>
                  {peerCohort && <td class="peer-col">{step.bmKey ? fmtBm(peerMed(step.bmKey), step.bmFmt || 'dollar') : ''}</td>}
                </tr>
                {step.dividerAfter && (
                  <tr class="step-divider"><td colspan={peerCohort ? "5" : "4"}></td></tr>
                )}
              </>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 3. Per Capita Expenditure pivot table with risk-adjusted comparison -->
    {(() => {
      const sec = ACO_SECTIONS.find(s => s.id === 'per-capita-expenditure')!;
      const pivot = sec.pivot!;
      // HCC risk score map for risk-adjusted expected expenditure
      const hccMap = {
        'ESRD': 'CMS_HCC_RiskScore_ESRD_PY',
        'DIS': 'CMS_HCC_RiskScore_DIS_PY',
        'AGDU': 'CMS_HCC_RiskScore_AGDU_PY',
        'AGND': 'CMS_HCC_RiskScore_AGND_PY',
      } as any;
      return (
        <section class="aco-section" id={sec.id}>
          <a href="#main-content" class="section-back">Back to top</a>
          <h2>{sec.title}</h2>
          {pivot.help && <p class="section-help">{pivot.help}</p>}
          <div style="overflow-x: auto;">
            <table class="pivot-table">
              <thead>
                <tr>
                  <th>Population Segment</th>
                  {pivot.periods.map(p => <th>{p.label}</th>)}
                  <th>Trend</th>
                  <th class="bm-col" title="Expected expenditure given this ACO's risk score: MSSP median × HCC risk score">Risk-Adj. Expected</th>
                  <th class="bm-col">Difference</th>
                </tr>
              </thead>
              <tbody>
                {pivot.segments.map(seg => {
                  const vals = pivot.periods.map(p => rawData[`${pivot.fieldPrefix}${seg.code}_${p.code}`]);
                  const first = vals[0];
                  const last = vals[vals.length - 1];
                  // Risk-adjusted expected: MSSP median PY expenditure for this segment × ACO's HCC score
                  const pyField = `Per_Capita_Exp_ALL_${seg.code}_PY`;
                  const msspMedPy = bmMedian(pyField);
                  const hccField = hccMap[seg.code];
                  const hccVal = hccField ? parseFloat(rawData[hccField] || '0') : null;
                  const actualPy = parseFloat(rawData[pyField] || '0');
                  const expected = (msspMedPy && hccVal) ? Math.round(msspMedPy * hccVal) : null;
                  const diff = (expected && actualPy) ? actualPy - expected : null;
                  return (
                    <tr>
                      <td>{seg.label}</td>
                      {vals.map(v => (
                        <td>
                          {isSuppressed(v)
                            ? <span class="val-suppressed" title="Value suppressed by CMS to protect beneficiary privacy (cell size <11).">*</span>
                            : isNotReported(v)
                              ? <span class="val-not-reported">{'\u2014'}</span>
                              : fmtRaw(v, pivot.format)
                          }
                        </td>
                      ))}
                      <td class={trendClass(first, last, true)}>
                        {trendArrow(first, last)}
                      </td>
                      <td class="bm-col">{expected ? '$' + expected.toLocaleString() : '\u2014'}</td>
                      <td class={diff !== null ? (diff < 0 ? 'bm-diff-pos' : 'bm-diff-neg') : ''}>
                        {diff !== null ? (diff < 0 ? '\u2212' : '+') + '$' + Math.abs(diff).toLocaleString() : '\u2014'}
                      </td>
                    </tr>
                  );
                })}
                {/* Total row */}
                {(() => {
                  const totalMed = bmMedian('Per_Capita_Exp_TOTAL_PY');
                  const totalPeerMed = peerMed('Per_Capita_Exp_TOTAL_PY');
                  const totalActual = parseFloat(rawData.Per_Capita_Exp_TOTAL_PY || '0');
                  return (
                    <tr class="total-row">
                      <td>Total</td>
                      {pivot.periods.map(p => (
                        <td>{p.code === 'PY' ? fmtRaw(rawData.Per_Capita_Exp_TOTAL_PY, 'dollar') : ''}</td>
                      ))}
                      <td></td>
                      <td class="bm-col">{totalMed ? '$' + Math.round(totalMed).toLocaleString() : ''}</td>
                      <td class="peer-col">{totalPeerMed ? '$' + Math.round(totalPeerMed).toLocaleString() : ''}</td>
                    </tr>
                  );
                })()}
              </tbody>
            </table>
          </div>
        </section>
      );
    })()}

