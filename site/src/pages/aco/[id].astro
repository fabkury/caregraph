                      <td>{seg.label}</td>
                      {vals.map(v => (
                        <td>
                          {isSuppressed(v)
                            ? <span class="val-suppressed" title="Value suppressed by CMS to protect beneficiary privacy (cell size <11).">*</span>
                            : isNotReported(v)
                              ? <span class="val-not-reported">{'\u2014'}</span>
                              : fmtRaw(v, pivot.format)
                          }
                        </td>
                      ))}
                      <td class={trendClass(first, last, true)}>
                        {trendArrow(first, last)}
                      </td>
                      <td class={codingGap !== null ? (codingGap > 0.02 ? 'coding-gap-pos' : codingGap < -0.02 ? 'coding-gap-neg' : 'coding-gap-zero') : ''}>
                        {codingGap !== null ? (codingGap >= 0 ? '+' : '') + codingGap.toFixed(3) : '\u2014'}
                      </td>
                      <td class="bm-col">{msspMedHcc !== null ? msspMedHcc.toFixed(3) : '\u2014'}</td>
