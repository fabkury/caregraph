                  // Coding intensity gap: HCC PY - Demographic PY
                  const hccPy = parseFloat(rawData[`CMS_HCC_RiskScore_${seg.code}_PY`] || '');
                  const demPy = parseFloat(rawData[`Demog_RiskScore_${seg.code}_PY`] || '');
                  const codingGap = (!isNaN(hccPy) && !isNaN(demPy)) ? hccPy - demPy : null;
                  const hccPyField = `CMS_HCC_RiskScore_${seg.code}_PY`;
                  const msspMedHcc = bmMedian(hccPyField);
                  return (
