              const peer = peerMed(row.bmKey || '');
              return (
                <tr>
                  <td>
                    {row.label}
                    {row.lowerIsBetter && <span class="measure-direction"> (lower is better)</span>}
                    {row.help && <span class="help-tip" title={row.help}>?</span>}
                    {row.bmKey && pctlBadge(row.bmKey) && (
                      <span class={`pctl-badge ${pctlClass(row.bmKey, row.lowerIsBetter)}`}>{pctlBadge(row.bmKey)}</span>
                    )}
                    {row.isMultiPathway && row.pathways && (
                      <details style="margin-top: 0.25rem; font-size: 0.8rem;">
                        <summary style="color: var(--color-text-muted); cursor: pointer;">Reporting pathways</summary>
                        <ul style="margin: 0.25rem 0 0 1rem; padding: 0; list-style: none; color: var(--color-text-muted);">
                          {row.pathways.map(pw => (
                            <li>{pw.label}: {pw.value === '\u2014' ? 'Not reported' : pw.value}</li>
                          ))}
                        </ul>
                      </details>
                    )}
                  </td>
                  <td>
                    {isSuppressed(row.value)
                      ? <span class="val-suppressed" title="Suppressed">*</span>
                      : row.value === '\u2014'
                        ? <span class="val-not-reported">{'\u2014'}</span>
                        : row.value
                    }
                  </td>
                  <td class="bm-col">{med !== null ? med.toFixed(2) : '\u2014'}</td>
                  {peerCohort && <td class="peer-col">{peer !== null ? peer.toFixed(2) : '\u2014'}</td>}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Quality Reporting Flags */}
      <h3 style="font-size: 1rem; margin-top: 1.5rem;">Quality Reporting Flags</h3>
      <div class="quality-flags">
        {QUALITY_FLAGS.map(flag => {
          const val = rawData[flag.key];
          const isYes = val === '1';
          const isNo = val === '0';
          return (
            <div class="quality-flag">
              <span class={`flag-icon ${isYes ? 'flag-icon-yes' : isNo ? 'flag-icon-no' : 'flag-icon-na'}`}>
                {isYes ? '\u2713' : isNo ? '\u2717' : '?'}
              </span>
              <span>{flag.label}</span>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Peer Cohort section -->
    {peerCohort && (
      <section class="aco-section" id="peer-cohort">
        <a href="#main-content" class="section-back">Back to top</a>
        <h2>Peer Cohort</h2>
        <p class="section-help">{peerDesc}</p>

        <details>
          <summary style="cursor: pointer; color: var(--color-primary); font-size: 0.9rem;">
            View {peerIds.length} peer ACOs
          </summary>
          <div class="peer-list">
            {peerIds.map(pid => (
              <a href={`/aco/${pid}/`} class="peer-chip">{pid}</a>
            ))}
          </div>
          <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
            Peers selected using weighted distance across 15 structural features (population acuity, composition, scale, care infrastructure, assignment type) within the {peerCohort.track_group} track partition.
            <a href="/methodology/">Learn more</a>
          </p>
        </details>
      </section>
    )}

    <!-- Network Participants -->
    {participants && participants.length > 0 && (
      <section class="aco-section" id="network-participants">
        <a href="#main-content" class="section-back">Back to top</a>
        <h2>Network Participants ({participants.length})</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Provider Name</th>
                <th>Type</th>
                <th>CCN</th>
                <th>Start Date</th>
              </tr>
            </thead>
            <tbody>
              {participants.slice(0, 200).map((p: any) => (
                <tr>
                  <td style="font-weight: 500;">
                    {p.ccn ? (
                      <a href={`/hospital/${p.ccn}/`}>{p.provider_name || p.ccn}</a>
                    ) : (
                      p.provider_name || '\u2014'
                    )}
                  </td>
                  <td>{p.provider_type || '\u2014'}</td>
                  <td><code>{p.ccn || p.tin || '\u2014'}</code></td>
                  <td>{p.start_date || '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {participants.length > 200 && (
          <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
            Showing 200 of {participants.length} participants. Download CSV for full list.
          </p>
        )}
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Providers participating in this ACO. Source: CMS ACO Participants.
        </p>
      </section>
    )}

    <!-- SNF Affiliates -->
    {snfAffiliates && snfAffiliates.length > 0 && (
      <section class="aco-section" id="snf-affiliates">
        <a href="#main-content" class="section-back">Back to top</a>
        <h2>SNF Affiliates ({snfAffiliates.length})</h2>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>SNF Name</th>
                <th>CCN</th>
                <th>State</th>
              </tr>
            </thead>
            <tbody>
              {snfAffiliates.map((a: any) => (
                <tr>
                  <td style="font-weight: 500;">
                    {a.snf_ccn ? (
                      <a href={`/snf/${a.snf_ccn}/`}>{a.snf_name || a.snf_ccn}</a>
                    ) : (
                      a.snf_name || '\u2014'
                    )}
                  </td>
                  <td><code>{a.snf_ccn || '\u2014'}</code></td>
                  <td>{a.state || '\u2014'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem;">
          Skilled Nursing Facilities affiliated with this ACO (3-day SNF waiver list). Source: CMS ACO SNF Affiliates.
        </p>
      </section>
    )}

    <!-- Uncovered fields (if any remain) -->
    {uncoveredEntries.length > 0 && (
      <section class="aco-section" id="other-fields">
        <h2>Other Fields ({uncoveredEntries.length})</h2>
        <p class="section-help">Additional raw MSSP fields not yet categorized into a domain section.</p>
        <table class="kv-table">
          <tbody>
            {uncoveredEntries.map(([key, value]) => (
              <tr>
                <td>{key}</td>
                <td>{(value as string) || '\u2014'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

  <!-- Related Entities -->
  {related.length > 0 && (
    <div class="card">
      <h2>Related Entities</h2>
      <ul class="related-list">
        {related.map((rel: any) => (
          <li>
            <span class={badgeClass(rel.type)}>{rel.type}</span>
            <a href={entityUrl(rel)}>{rel.name}</a>
            {rel.context && <span class="related-context">{rel.context}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  {allDataRows.length > 0 && (
    <div class="aco-section" id="all-data">
      <h2>All Data</h2>
      <p class="section-help">
        Every labeled MSSP field for this ACO, with national medians and
        percentiles where a benchmark is available.
      </p>
      <p style="margin-bottom: 0.75rem;">
        <a href={allDataCsvUri} download={`aco_${id}_all_data.csv`} class="btn">
          Download CSV
        </a>
      </p>
      <details>
        <summary style="cursor: pointer; color: var(--color-primary); margin-bottom: 0.75rem;">
          Show {allDataRows.length.toLocaleString()} rows
        </summary>
        <div style="overflow-x: auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Source</th>
                <th>Metric</th>
                <th style="text-align:right;">Value</th>
                <th style="text-align:right;">National Median</th>
                <th>Pctl.</th>
                <th>Raw key</th>
              </tr>
            </thead>
            <tbody>
              {allDataRows.map(r => (
                <tr>
                  <td style="font-size: 0.8rem; color: var(--color-text-muted);">{r.group}</td>
                  <td style="font-weight: 500;">{r.label}</td>
                  <td style="text-align:right; font-variant-numeric:tabular-nums;">{r.value}</td>
                  <td class="bm-col" style="text-align:right;">{r.bmMedian}</td>
                  <td>
                    {r.percentile !== undefined && (
                      <span class={`pctl-badge ${allDataPctlClass(r.percentile)}`}>p{r.percentile}</span>
                    )}
                  </td>
                  <td><code style="font-size: 0.75rem;">{r.rawKey}</code></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>
    </div>
  )}

  <div class="methodology-stub">
    <strong>Methodology</strong>
    <p>
      Data source: <strong>{provenance?.dataset_name}</strong>
      (dataset ID: <code>{provenance?.dataset_id}</code>).
      Vintage: {provenance?.vintage}.
      Downloaded: {provenance?.download_date}.
      Rows in source: {provenance?.row_count?.toLocaleString()}.
    </p>
    <p>
      <em>MSSP ACO Performance</em> reports financial and quality performance
      for Accountable Care Organizations participating in the Medicare Shared Savings Program.
      Savings/losses are calculated against risk-adjusted, regionally-weighted benchmarks.
    </p>
    <p>
      <a href="/methodology/">Full methodology &rarr;</a>
    </p>
  </div>

  <script>
    import { isPinned, addPin, removePin } from '../../scripts/workspace';

    const pinBtn = document.getElementById('pin-btn') as HTMLButtonElement | null;
    if (pinBtn) {
      const entityType = pinBtn.dataset.entityType!;
      const entityId = pinBtn.dataset.entityId!;
      const entityName = pinBtn.dataset.entityName!;

      function updatePinLabel() {
        if (!pinBtn) return;
        if (isPinned(entityType, entityId)) {
          pinBtn.textContent = 'Unpin from Workspace';
          pinBtn.style.borderColor = 'var(--color-warning)';
          pinBtn.style.color = 'var(--color-warning)';
        } else {
          pinBtn.textContent = 'Pin to Workspace';
          pinBtn.style.borderColor = '';
          pinBtn.style.color = '';
        }
      }

      pinBtn.addEventListener('click', () => {
        if (isPinned(entityType, entityId)) {
          removePin(entityType, entityId);
        } else {
          addPin(entityType, entityId, entityName);
        }
        updatePinLabel();
      });

      updatePinLabel();
    }
  </script>
</BaseLayout>
