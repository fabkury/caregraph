                        : (() => {
                            const num = parseFloat(rawData[w.key] || '0');
                            return isNaN(num) ? rawData[w.key] : (num * 100).toFixed(1) + '%';
                          })()
                    }
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      );
    })()}

